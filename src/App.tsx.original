async function apiRequest<T>(path: string, options?: RequestInit): Promise<T> {
  const response = await fetch(path, {
    ...options,
    headers: {
      "content-type": "application/json",
      ...(options?.headers ?? {}),
    },
  });
  const data = await response.json();
  if (!response.ok) {
    throw new Error(data.error || "请求失败");
  }
  return data as T;
}

function readImageFile(file: File): Promise<string> {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(String(reader.result || ""));
    reader.onerror = () => reject(new Error("图片读取失败"));
    reader.readAsDataURL(file);
  });
}

function App() {
  const [route, setRoute] = useState<Route>(normalizeRoute(window.location.pathname));
  const [products, setProducts] = useState<Product[]>([]);
  const [stores, setStores] = useState<StoreLocation[]>([]);
  const [batchSale, setBatchSale] = useState<BatchSale>(emptyBatchSale);
  const [inventory, setInventory] = useState<InventoryAllocation>({});
  const [orders, setOrders] = useState<Order[]>([]);
  const [activeRole, setActiveRole] = useState<RoleId>("hq");
  const [apiError, setApiError] = useState<string | null>(null);

  useEffect(() => {
    const onPop = () => setRoute(normalizeRoute(window.location.pathname));
    window.addEventListener("popstate", onPop);
    return () => window.removeEventListener("popstate", onPop);
  }, []);

  useEffect(() => {
    void refreshData();
  }, []);

  const refreshData = async () => {
    try {
      const data = await apiRequest<BootstrapPayload>("/api/bootstrap");
      setProducts(data.products);
      setStores(data.stores);
      setBatchSale(data.batchSale);
      setInventory(data.inventory);
      setOrders(data.orders);
      setApiError(null);
    } catch (error) {
      setApiError(error instanceof Error ? error.message : "后端暂不可用，暂时无法读取门店数据");
    }
  };

  const navigate = (nextRoute: Route) => {
    window.history.pushState({}, "", nextRoute);
    setRoute(nextRoute);
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  const createOrder = async (order: Order) => {
    try {
      const endpoint = order.type === "pos" ? "/api/admin/pos-orders" : "/api/orders";
      const data = await apiRequest<{ order: Order; inventory: InventoryAllocation }>(endpoint, {
        method: "POST",
        body: JSON.stringify(order),
      });
      setOrders((current) => [data.order, ...current.filter((item) => item.id !== data.order.id)]);
      setInventory(data.inventory);
      setApiError(null);
      return data.order;
    } catch (error) {
      setApiError(error instanceof Error ? error.message : "订单保存失败");
      return null;
    }
  };

  return (
    <div className="min-h-screen bg-white text-fg">
      {route === "/" ? (
        <CustomerHeader cartCount={0} />
      ) : (
        <AdminHeader
          route={route}
          navigate={navigate}
          activeRole={activeRole}
          setActiveRole={setActiveRole}
          stores={stores}
        />
      )}
      {products.length === 0 || stores.length === 0 ? (
        <LoadingShell />
      ) : route === "/" ? (
        <CustomerPage
          products={products}
          stores={stores}
          batchSale={batchSale}
          inventory={inventory}
          createOrder={createOrder}
        />
      ) : null}
      {apiError && (
        <div className="fixed bottom-4 left-1/2 z-[80] max-w-[92vw] -translate-x-1/2 rounded-full bg-fg px-5 py-3 text-sm text-white shadow-soft">
          {apiError}
        </div>
      )}
      {route === "/admin" && products.length > 0 && stores.length > 0 && (
        <AdminPage
          products={products}
          setProducts={setProducts}
          stores={stores}
          setStores={setStores}
          batchSale={batchSale}
          setBatchSale={setBatchSale}
          inventory={inventory}
          setInventory={setInventory}
          orders={orders}
          setOrders={setOrders}
          activeRole={activeRole}
          navigate={navigate}
          setApiError={setApiError}
        />
      )}
      {route === "/admin/pos" && products.length > 0 && stores.length > 0 && (
        <PosPage
          products={products}
          stores={stores}
          inventory={inventory}
          activeRole={activeRole}
          createOrder={createOrder}
          navigate={navigate}
        />
      )}
    </div>
  );
}

function normalizeRoute(pathname: string): Route {
  if (pathname === "/admin" || pathname === "/admin/pos") return pathname;
  return "/";
}

function LoadingShell() {
  return (
    <main className="flex min-h-[70svh] items-center justify-center px-4 py-24">
      <div className="rounded-lg border border-border bg-white p-6 text-center shadow-soft">
        <Flame className="mx-auto h-8 w-8 text-accent" />
        <p className="mt-4 font-semibold">正在读取 Mio Bakery 数据</p>
        <p className="mt-2 text-sm text-fg/52">商品、门店、库存和订单会从本地 SQLite 加载。</p>
      </div>
    </main>
  );
}

function CustomerHeader({ cartCount }: { cartCount: number }) {
  const [menuOpen, setMenuOpen] = useState(false);
  const [scrolled, setScrolled] = useState(false);

  useEffect(() => {
    const onScroll = () => setScrolled(window.scrollY > 20);
    window.addEventListener("scroll", onScroll, { passive: true });
    return () => window.removeEventListener("scroll", onScroll);
  }, []);

  return (
    <header
      className={`fixed inset-x-0 top-0 z-50 transition-all duration-300 ${
        scrolled ? "bg-white/90 backdrop-blur-md border-b border-border" : "bg-transparent"
      }`}
    >
      <div className="mx-auto flex h-16 max-w-7xl items-center justify-between px-5 sm:px-8">
        <a href="/" className="font-display text-lg font-bold tracking-tight text-fg" aria-label="Mio 首页">
          Mio
        </a>
        <nav className="hidden items-center gap-6 text-sm font-medium text-muted lg:flex">
          <a href="#today" className="transition hover:text-fg">今日</a>
          <a href="#menu" className="transition hover:text-fg">面包</a>
          <a href="#order-lookup" className="transition hover:text-fg">查单</a>
          <a href="#stores" className="transition hover:text-fg">门店</a>
        </nav>
        <div className="flex items-center gap-3">
          {cartCount > 0 && (
            <span className="flex h-6 items-center justify-center rounded-sm bg-accent px-2 text-xs font-bold text-white">
              {cartCount}
            </span>
          )}
          <button
            type="button"
            onClick={() => setMenuOpen((open) => !open)}
            className="inline-flex h-9 w-9 items-center justify-center rounded-md border border-border text-fg lg:hidden"
            aria-label="菜单"
          >
            {menuOpen ? <X className="h-4 w-4" /> : <Menu className="h-4 w-4" />}
          </button>
        </div>
      </div>
      {menuOpen && (
        <div className="border-t border-border bg-white px-5 pb-4 lg:hidden">
          <div className="grid gap-0 pt-2">
            {["今日","面包","查单","门店"].map((label) => (
              <a
                key={label}
                href={`#${label === "今日" ? "today" : label === "面包" ? "menu" : label === "查单" ? "order-lookup" : "stores"}`}
                onClick={() => setMenuOpen(false)}
                className="py-3 text-sm font-medium text-fg border-b border-border0"
              >
                {label}
              </a>
            ))}
          </div>
        </div>
      )}
    </header>
  );
}

function AdminHeader({
  route,
  navigate,
  activeRole,
  setActiveRole,
  stores,
}: {
  route: Route;
  navigate: (route: Route) => void;
  activeRole: RoleId;
  setActiveRole: (role: RoleId) => void;
  stores: StoreLocation[];
}) {
  const roleOptions = [
    { id: "hq" as RoleId, name: "总部账号" },
    ...stores.map((store) => ({ id: store.id as RoleId, name: store.name })),
  ];

  return (
    <header className="sticky top-0 z-40 border-b border-border bg-white/90 backdrop-blur-md">
      <div className="mx-auto flex max-w-7xl flex-col gap-3 px-5 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-8 lg:px-8">
        <div className="flex items-center gap-3">
          <span className="flex h-9 w-9 items-center justify-center rounded-full bg-fg text-white">
            <Settings2 className="h-4 w-4" />
          </span>
          <div>
            <p className="text-sm font-semibold tracking-tight">Mio Bakery 运营后台</p>
            <p className="text-xs text-fg/50">总部与门店共用的管理入口</p>
          </div>
        </div>
        <div className="flex flex-wrap items-center gap-2">
          <select
            className="input-field h-10 min-w-44 rounded-full py-0 text-sm"
            value={activeRole}
            onChange={(event) => setActiveRole(event.target.value as RoleId)}
            aria-label="选择后台角色"
          >
            {roleOptions.map((role) => (
              <option key={role.id} value={role.id}>
                {role.name}
              </option>
            ))}
          </select>
          <button
            type="button"
            onClick={() => navigate("/admin")}
            className={`admin-nav-button ${route === "/admin" ? "bg-fg text-white" : "bg-white text-fg"}`}
          >
            <ClipboardList className="h-4 w-4" />
            后台
          </button>
          <button
            type="button"
            onClick={() => navigate("/admin/pos")}
            className={`admin-nav-button ${route === "/admin/pos" ? "bg-fg text-white" : "bg-white text-fg"}`}
          >
            <ReceiptText className="h-4 w-4" />
            收银
          </button>
        </div>
      </div>
    </header>
  );
}

function CustomerPage({
  products,
  stores,
  batchSale,
  inventory,
  createOrder,
}: {
  products: Product[];
  stores: StoreLocation[];
  batchSale: BatchSale;
  inventory: InventoryAllocation;
  createOrder: (order: Order) => Promise<Order | null>;
}) {
  const [activeCategory, setActiveCategory] = useState<Category | "全部">("全部");
  const [cart, setCart] = useState<Record<string, number>>({});
  const [pickupStoreId, setPickupStoreId] = useState<StoreId>("store-a");
  const [sourceStoreId, setSourceStoreId] = useState<StoreId>("store-a");
  const [deliveryMethod, setDeliveryMethod] = useState<DeliveryMethod>("门店自提");
  const [paymentMethod, setPaymentMethod] = useState<PaymentMethod>("微信转账");
  const [receiver, setReceiver] = useState("");
  const [phone, setPhone] = useState("");
  const [address, setAddress] = useState("");
  const [customer, setCustomer] = useState<Customer | null>(() => {
    try {
      const saved = window.localStorage.getItem("mio-customer");
      return saved ? (JSON.parse(saved) as Customer) : null;
    } catch {
      return null;
    }
  });
  const [memberMode, setMemberMode] = useState<"login" | "register">("register");
  const [memberName, setMemberName] = useState("");
  const [memberPhone, setMemberPhone] = useState("");
  const [memberPassword, setMemberPassword] = useState("");
  const [memberMessage, setMemberMessage] = useState("");
  const [successOrder, setSuccessOrder] = useState<Order | null>(null);
  const [lookupCode, setLookupCode] = useState("");
  const [lookupOrder, setLookupOrder] = useState<Order | null>(null);
  const [lookupMessage, setLookupMessage] = useState("");
  const [mobileCheckoutOpen, setMobileCheckoutOpen] = useState(false);

  const publishedProducts = products.filter((product) => product.isPublished);
  const featuredProducts = batchSale.featuredProductIds
    .map((productId) => products.find((product) => product.id === productId))
    .filter(Boolean) as Product[];
  const filteredProducts =
    activeCategory === "全部"
      ? publishedProducts
      : publishedProducts.filter((product) => product.category === activeCategory);
  const pickupStores = stores.filter(
    (store) => store.pickupOpen && batchSale.pickupStoreIds.includes(store.id),
  );
  const selectedPickupStore = stores.find((store) => store.id === pickupStoreId) ?? stores[0];
  const cartItems = useMemo(
    () =>
      Object.entries(cart)
        .map(([productId, qty]) => {
          const product = products.find((item) => item.id === productId);
          return product && qty > 0
            ? { productId, name: product.name, qty, price: product.price }
            : null;
        })
        .filter(Boolean) as Order["items"],
    [cart, products],
  );
  const subtotal = cartItems.reduce((sum, item) => sum + item.qty * item.price, 0);
  const cartCount = cartItems.reduce((sum, item) => sum + item.qty, 0);
  const shippingFee =
    deliveryMethod === "门店自提" || subtotal >= batchSale.freeShippingThreshold
      ? 0
      : batchSale.baseShippingFee;
  const total = subtotal + shippingFee;

  const getAvailable = (productId: string, storeId = pickupStoreId) => {
    const allocation = inventory[productId];
    if (!allocation) return 0;
    return Math.max(0, allocation.stores[storeId] - allocation.sold[storeId]);
  };

  const updateCart = (productId: string, delta: number) => {
    if (!batchSale.isOpen) return;
    const available = getAvailable(productId);
    setCart((current) => {
      const nextQty = Math.max(0, Math.min(available, (current[productId] ?? 0) + delta));
      const next = { ...current, [productId]: nextQty };
      if (nextQty === 0) delete next[productId];
      return next;
    });
  };

  const submitOrder = async () => {
    if (!batchSale.isOpen || cartItems.length === 0) return;
    if (!customer) {
      setMemberMessage("请先用姓名和手机号注册或登录，再提交订购单。");
      setMobileCheckoutOpen(true);
      return;
    }
    const order: Order = {
      id: "",
      type: "online",
      items: cartItems,
      subtotal,
      shippingFee,
      total,
      deliveryMethod,
      paymentMethod,
      status: deliveryMethod === "门店自提" ? "待生产" : "待发货",
      customerId: customer.id,
      customerName: customer.name,
      customerPhone: customer.phone,
      paymentStatus: "待付款确认",
      sourceStoreId,
      pickupStoreId,
      receiver: deliveryMethod === "门店自提" ? customer.name : receiver || customer.name,
      phone: deliveryMethod === "门店自提" ? customer.phone : phone || customer.phone,
      address: deliveryMethod === "门店自提" ? undefined : address,
      createdAt: "刚刚",
    };
    const savedOrder = await createOrder(order);
    if (savedOrder) {
      setSuccessOrder(savedOrder);
      setMobileCheckoutOpen(false);
      setCart({});
    }
  };

  const submitMember = async () => {
    try {
      const nextCustomer = await apiRequest<Customer>(
        memberMode === "register" ? "/api/customers/register" : "/api/customers/login",
        {
          method: "POST",
          body: JSON.stringify({
            name: memberName,
            phone: memberPhone,
            password: memberPassword,
          }),
        },
      );
      setCustomer(nextCustomer);
      window.localStorage.setItem("mio-customer", JSON.stringify(nextCustomer));
      setReceiver((current) => current || nextCustomer.name);
      setPhone((current) => current || nextCustomer.phone);
      setMemberMessage("");
    } catch (error) {
      setMemberMessage(error instanceof Error ? error.message : "会员信息保存失败");
    }
  };

  const logoutMember = () => {
    setCustomer(null);
    window.localStorage.removeItem("mio-customer");
  };

  const lookupCustomerOrder = async () => {
    if (!lookupCode.trim()) return;
    try {
      const order = await apiRequest<Order>(`/api/orders/lookup?code=${encodeURIComponent(lookupCode.trim())}`);
      setLookupOrder(order);
      setLookupMessage("");
    } catch (error) {
      setLookupOrder(null);
      setLookupMessage(error instanceof Error ? error.message : "没有找到订单");
    }
  };

  return (
    <main className="pb-24 lg:pb-0">
      <section id="today" className="bg-white pt-20">
        <div className="mx-auto flex min-h-[calc(100svh-5rem)] max-w-7xl flex-col justify-center px-5 py-16 sm:px-8">
          <h1 className="font-display text-7xl font-bold tracking-tighter text-fg sm:text-9xl">
            Mio
          </h1>
          <p className="mt-4 text-2xl font-medium text-muted sm:text-3xl">
            不多做，只为你烤。
          </p>
          <p className="mt-6 max-w-xl text-base leading-relaxed text-muted">
            Mio 是意大利语"我的"。我们相信每一炉面包都该"有主"——在揉面之前，就知道为谁而烤。没有隔夜面包，没有多余包装，只有刚出炉的温度，和愿意等待的人。
          </p>
          <div className="mt-10">
            <a
              href="#menu"
              className="inline-flex items-center gap-2 rounded-md bg-fg px-6 py-3 text-sm font-medium text-white transition hover:bg-fg/90"
            >
              开始预订 →
            </a>
          </div>
          <div className="mt-8">
            <span className="inline-flex items-center gap-2 rounded-full bg-surface px-3 py-1 text-xs font-medium text-muted">
              {batchSale.isOpen ? `今日 2 炉 · ${batchSale.deadline} 截止` : "下一炉准备中"}
            </span>
          </div>
          <div className="mt-12 w-full max-w-md lg:mt-16 lg:max-w-sm">
            <TodayBakeCard
              batchSale={batchSale}
              products={featuredProducts.length > 0 ? featuredProducts : publishedProducts.slice(0, 4)}
              allProducts={publishedProducts}
              getAvailable={getAvailable}
            />
          </div>
        </div>
      </section>

      <FeatureEntrances />

      <section id="order-lookup" className="border-b border-border bg-white py-12">
        <div className="mx-auto grid max-w-7xl gap-6 px-4 sm:px-6 lg:grid-cols-[.8fr_1.2fr] lg:px-8">
          <div>
            <p className="text-sm font-semibold text-accent">订单查询</p>
            <h2 className="mt-2 text-3xl font-semibold">顾客可用订单号或取货码查询。</h2>
            <p className="mt-3 text-fg/58">下单成功后会生成订单号和 6 位取货码，自提和配送都可以查状态。</p>
          </div>
          <div className="rounded-lg border border-border bg-white p-4 sm:p-5">
            <div className="grid gap-3 sm:grid-cols-[1fr_auto]">
              <input
                className="input-field bg-white"
                value={lookupCode}
                onChange={(event) => setLookupCode(event.target.value)}
                placeholder="输入订单号或 6 位取货码"
              />
              <button
                type="button"
                onClick={lookupCustomerOrder}
                className="inline-flex items-center justify-center gap-2 rounded-full bg-fg px-5 py-3 text-sm font-semibold text-white"
              >
                <Search className="h-4 w-4" />
                查询
              </button>
            </div>
            {lookupMessage && <p className="mt-3 text-sm text-accent">{lookupMessage}</p>}
            {lookupOrder && (
              <OrderSummaryCard order={lookupOrder} stores={stores} />
            )}
          </div>
        </div>
      </section>

      <section id="about" className="bg-white">
        <div className="mx-auto grid max-w-7xl gap-8 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:px-8">
          <div>
            <h2 className="font-display text-4xl font-bold tracking-tighter text-fg sm:text-5xl">
              不为货架烤面包
            </h2>
          </div>
          <p className="text-base leading-relaxed text-muted sm:text-lg">
            工业化面包为了"随时能买到"而存在，隔夜、添加剂、过度包装是常态。Mio 选择相反的路：按订单生产，按门店分配，按出炉时间交付。你拿到的面包，距离出炉不到几小时。
          </p>
        </div>
      </section>

      <section id="pickup" className="bg-surface/70 py-14">
        <div className="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div className="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p className="text-sm font-semibold text-accent">本轮状态</p>
              <h2 className="mt-2 text-3xl font-semibold sm:text-4xl">
                {batchSale.isOpen ? "今天开放预订" : "本轮预订未开放"}
              </h2>
              <p className="mt-3 max-w-2xl text-fg/62">{batchSale.note}</p>
            </div>
            <div className={`rounded-full px-5 py-3 text-sm font-semibold ${batchSale.isOpen ? "bg-green-50 text-green-800" : "bg-stone-200 text-stone-700"}`}>
              {batchSale.isOpen ? `${batchSale.deadline} 截止` : "请等待门店群通知"}
            </div>
          </div>
          <div className="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
            {pickupStores.map((store) => (
              <button
                key={store.id}
                type="button"
                onClick={() => {
                  setPickupStoreId(store.id);
                  setSourceStoreId(store.id);
                }}
                className={`rounded-lg border p-5 text-left transition ${
                  pickupStoreId === store.id
                    ? "border-border bg-fg text-white shadow-soft"
                    : "border-border bg-white text-fg hover:-translate-y-1 hover:shadow-soft"
                }`}
              >
                <p className="text-lg font-semibold">{store.name}</p>
                <p className={`mt-2 text-sm ${pickupStoreId === store.id ? "text-white/70" : "text-fg/56"}`}>
                  {store.address}
                </p>
                <p className={`mt-4 text-xs ${pickupStoreId === store.id ? "text-white/58" : "text-fg/42"}`}>
                  来源码 {store.sourceCode}
                </p>
              </button>
            ))}
          </div>
        </div>
      </section>

      <section id="menu" className="mx-auto grid max-w-7xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1fr_390px] lg:px-8">
        <div>
          <div className="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p className="text-sm font-semibold text-accent">全部面包</p>
              <h2 className="mt-2 text-3xl font-semibold sm:text-4xl">本轮可查看的产品目录</h2>
            </div>
            <div className="flex gap-2 overflow-x-auto pb-1">
              {["全部", ...categories].map((category) => (
                <button
                  key={category}
                  type="button"
                  onClick={() => setActiveCategory(category as Category | "全部")}
                  className={`min-w-fit rounded-full px-4 py-2 text-sm font-medium transition ${
                    activeCategory === category
                      ? "bg-fg text-white"
                      : "bg-white text-fg/70 hover:bg-surface"
                  }`}
                >
                  {category}
                </button>
              ))}
            </div>
          </div>

          <div className="mt-8 grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
            {filteredProducts.map((product) => (
              <ProductTile
                key={product.id}
                product={product}
                available={getAvailable(product.id)}
                qty={cart[product.id] ?? 0}
                canOrder={batchSale.isOpen}
                onAdd={() => updateCart(product.id, 1)}
                onRemove={() => updateCart(product.id, -1)}
              />
            ))}
          </div>
        </div>

        <aside className="hidden lg:sticky lg:top-6 lg:block lg:self-start">
          <CheckoutPanel
            batchSale={batchSale}
            cartItems={cartItems}
            subtotal={subtotal}
            shippingFee={shippingFee}
            total={total}
            stores={stores}
            pickupStore={selectedPickupStore}
            pickupStoreId={pickupStoreId}
            setPickupStoreId={setPickupStoreId}
            sourceStoreId={sourceStoreId}
            setSourceStoreId={setSourceStoreId}
            deliveryMethod={deliveryMethod}
            setDeliveryMethod={setDeliveryMethod}
            paymentMethod={paymentMethod}
            setPaymentMethod={setPaymentMethod}
            receiver={receiver}
            setReceiver={setReceiver}
            phone={phone}
            setPhone={setPhone}
            address={address}
            setAddress={setAddress}
            submitOrder={submitOrder}
            successOrder={successOrder}
            customer={customer}
            memberMode={memberMode}
            setMemberMode={setMemberMode}
            memberName={memberName}
            setMemberName={setMemberName}
            memberPhone={memberPhone}
            setMemberPhone={setMemberPhone}
            memberPassword={memberPassword}
            setMemberPassword={setMemberPassword}
            memberMessage={memberMessage}
            submitMember={submitMember}
            logoutMember={logoutMember}
          />
        </aside>
      </section>

      <section id="stores" className="border-t border-border bg-white py-14">
        <div className="mx-auto grid max-w-7xl gap-6 px-4 sm:px-6 lg:grid-cols-[.8fr_1.2fr] lg:px-8">
          <div>
            <p className="text-sm font-semibold text-accent">门店信息</p>
            <h2 className="mt-2 text-3xl font-semibold">中央厨房出炉，多门店自提。</h2>
          </div>
          <div className="grid gap-3 sm:grid-cols-2">
            {stores.map((store) => (
              <div key={store.id} className="rounded-lg border border-border bg-white p-4">
                <p className="font-semibold">{store.name}</p>
                <p className="mt-1 text-sm text-fg/58">{store.address}</p>
                <p className="mt-3 text-xs text-fg/40">自提码 {store.sourceCode}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <MobileCheckoutBar
        cartCount={cartCount}
        total={total}
        isOpen={mobileCheckoutOpen}
        setOpen={setMobileCheckoutOpen}
        checkout={
          <CheckoutPanel
            batchSale={batchSale}
            cartItems={cartItems}
            subtotal={subtotal}
            shippingFee={shippingFee}
            total={total}
            stores={stores}
            pickupStore={selectedPickupStore}
            pickupStoreId={pickupStoreId}
            setPickupStoreId={setPickupStoreId}
            sourceStoreId={sourceStoreId}
            setSourceStoreId={setSourceStoreId}
            deliveryMethod={deliveryMethod}
            setDeliveryMethod={setDeliveryMethod}
            paymentMethod={paymentMethod}
            setPaymentMethod={setPaymentMethod}
            receiver={receiver}
            setReceiver={setReceiver}
            phone={phone}
            setPhone={setPhone}
            address={address}
            setAddress={setAddress}
            submitOrder={submitOrder}
            successOrder={successOrder}
            customer={customer}
            memberMode={memberMode}
            setMemberMode={setMemberMode}
            memberName={memberName}
            setMemberName={setMemberName}
            memberPhone={memberPhone}
            setMemberPhone={setMemberPhone}
            memberPassword={memberPassword}
            setMemberPassword={setMemberPassword}
            memberMessage={memberMessage}
            submitMember={submitMember}
            logoutMember={logoutMember}
          />
        }
      />
    </main>
  );
}

function TrustItem({ icon: Icon, label, desc }: { icon: LucideIcon; label: string; desc: string }) {
  return (
    <div className="flex items-center gap-4 border-border py-5 lg:border-r lg:last:border-r-0">
      <span className="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-surface text-accent">
        <Icon className="h-5 w-5" />
      </span>
      <span>
        <span className="block font-semibold">{label}</span>
        <span className="text-sm text-fg/58">{desc}</span>
      </span>
    </div>
  );
}

function ProductTile({
  product,
  available,
  qty,
  canOrder,
  onAdd,
  onRemove,
}: {
  product: Product;
  available: number;
  qty: number;
  canOrder: boolean;
  onAdd: () => void;
  onRemove: () => void;
}) {
  return (
    <article className="group overflow-hidden rounded-lg border border-border bg-white">
      <div className="h-40 bg-surface flex items-center justify-center">
        <ProductVisual product={product} />
      </div>
      <div className="p-4">
        <h3 className="text-base font-semibold text-fg">{product.name}</h3>
        <div className="mt-1 flex items-center justify-between">
          <span className="text-xs text-muted-light">{product.weight}</span>
          <span className="text-sm font-bold text-fg">¥{product.price}</span>
        </div>
        <p className="mt-2 text-xs text-muted line-clamp-2">{product.description}</p>
        <div className="mt-4 flex items-center justify-between">
          <span className="text-xs text-muted">
            {canOrder ? `剩余 ${available}` : "待开放预订"}
          </span>
          {qty > 0 ? (
            <div className="flex items-center gap-2 rounded-full bg-surface p-1">
              <button type="button" onClick={onRemove} className="counter-button" aria-label="减少">
                <Minus className="h-4 w-4" />
              </button>
              <span className="w-7 text-center text-sm font-semibold">{qty}</span>
              <button type="button" onClick={onAdd} className="counter-button bg-fg text-white" aria-label="增加">
                <Plus className="h-4 w-4" />
              </button>
            </div>
          ) : (
            <button
              type="button"
              onClick={onAdd}
              disabled={!canOrder || available === 0}
              className="inline-flex h-8 w-8 items-center justify-center rounded-md bg-fg text-white transition hover:bg-fg/90 disabled:opacity-30 disabled:cursor-not-allowed"
            >
              <Plus className="h-4 w-4" />
            </button>
          )}
        </div>
      </div>
    </article>
  );
}

function ProductVisual({ product }: { product: Product }) {
  if (product.imageUrl) {
    return (
      <div className="relative h-36 overflow-hidden bg-surface">
        <img src={product.imageUrl} alt={product.name} className="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
        {product.featured && (
          <span className="absolute left-4 top-4 rounded-full bg-white/88 px-3 py-1 text-xs font-semibold text-fg">
            本轮主推
          </span>
        )}
      </div>
    );
  }

  const breadSvg: Record<Category, ReactNode> = {
    "欧包/坚果": (
      <svg viewBox="0 0 160 100" className="h-20 w-32 drop-shadow-lg">
        <ellipse cx="80" cy="56" rx="62" ry="34" fill="#a67c52" />
        <ellipse cx="80" cy="53" rx="58" ry="30" fill="#c4956a" />
        <ellipse cx="80" cy="50" rx="52" ry="26" fill="#d4a574" />
        <path d="M42 46 Q58 38 74 46 Q90 38 106 46 Q122 38 138 46" stroke="#8b6239" strokeWidth="2.5" fill="none" strokeLinecap="round" />
        <circle cx="32" cy="58" r="3.5" fill="#6b4423" opacity="0.7" />
        <circle cx="128" cy="64" r="3" fill="#6b4423" opacity="0.6" />
        <circle cx="95" cy="70" r="2.5" fill="#6b4423" opacity="0.5" />
        <circle cx="58" cy="74" r="3" fill="#6b4423" opacity="0.6" />
        <circle cx="110" cy="52" r="2" fill="#6b4423" opacity="0.5" />
      </svg>
    ),
    "吐司": (
      <svg viewBox="0 0 120 100" className="h-24 w-28 drop-shadow-lg">
        <rect x="18" y="22" width="84" height="68" rx="14" fill="#a67c52" />
        <rect x="23" y="27" width="74" height="58" rx="10" fill="#c4956a" />
        <rect x="28" y="32" width="64" height="48" rx="6" fill="#d4a574" />
        <path d="M32 32 Q60 18 88 32" stroke="#a67c52" strokeWidth="3" fill="none" strokeLinecap="round" />
        <line x1="38" y1="48" x2="82" y2="48" stroke="#a67c52" strokeWidth="1.5" opacity="0.5" />
        <line x1="38" y1="60" x2="82" y2="60" stroke="#a67c52" strokeWidth="1.5" opacity="0.5" />
        <line x1="38" y1="72" x2="82" y2="72" stroke="#a67c52" strokeWidth="1.5" opacity="0.5" />
      </svg>
    ),
    "恰巴塔": (
      <svg viewBox="0 0 160 90" className="h-20 w-36 drop-shadow-lg">
        <path d="M18 52 Q28 22 58 28 Q88 18 118 32 Q148 28 142 58 Q136 76 106 72 Q76 82 46 72 Q16 78 18 52Z" fill="#a67c52" />
        <path d="M22 50 Q32 26 58 30 Q84 22 114 34 Q140 32 136 54" stroke="#8b6239" strokeWidth="2.5" fill="none" strokeLinecap="round" />
        <circle cx="48" cy="48" r="5" fill="#8b6239" opacity="0.35" />
        <circle cx="88" cy="58" r="6" fill="#8b6239" opacity="0.3" />
        <circle cx="120" cy="46" r="4" fill="#8b6239" opacity="0.4" />
        <circle cx="68" cy="64" r="4.5" fill="#8b6239" opacity="0.35" />
        <circle cx="100" cy="40" r="3" fill="#8b6239" opacity="0.4" />
      </svg>
    ),
    "贝果/海盐卷": (
      <svg viewBox="0 0 100 100" className="h-24 w-24 drop-shadow-lg">
        <circle cx="50" cy="50" r="36" fill="#a67c52" />
        <circle cx="50" cy="50" r="22" fill="none" stroke="#c4956a" strokeWidth="14" />
        <circle cx="50" cy="50" r="22" fill="#d4a574" />
        <circle cx="50" cy="50" r="15" fill="#e8c39e" />
        <circle cx="35" cy="34" r="2.5" fill="#fff" opacity="0.5" />
        <circle cx="66" cy="66" r="2" fill="#fff" opacity="0.4" />
        <circle cx="66" cy="34" r="2.5" fill="#fff" opacity="0.5" />
        <circle cx="35" cy="66" r="2" fill="#fff" opacity="0.4" />
      </svg>
    ),
    "软欧包": (
      <svg viewBox="0 0 140 90" className="h-20 w-32 drop-shadow-lg">
        <ellipse cx="70" cy="52" rx="58" ry="30" fill="#a67c52" />
        <ellipse cx="70" cy="49" rx="54" ry="26" fill="#c4956a" />
        <ellipse cx="70" cy="46" rx="48" ry="22" fill="#d4a574" />
        <ellipse cx="70" cy="44" rx="42" ry="18" fill="#e8c39e" opacity="0.5" />
        <path d="M38 42 Q55 35 72 42 Q89 35 106 42" stroke="#a67c52" strokeWidth="2" fill="none" strokeLinecap="round" />
        <path d="M48 38 Q60 32 72 38 Q84 32 96 38" stroke="#a67c52" strokeWidth="1.5" fill="none" strokeLinecap="round" />
      </svg>
    ),
  };

  return (
    <div className={`relative h-36 overflow-hidden bg-gradient-to-br ${product.imageTone} flex items-center justify-center`}>
      {breadSvg[product.category]}
      {product.featured && (
        <span className="absolute left-4 top-4 rounded-full bg-white/82 px-3 py-1 text-xs font-semibold text-fg">
          本轮主推
        </span>
      )}
    </div>
  );
}

function ProductAdminPreview({ product }: { product: Product }) {
  if (product.imageUrl) {
    return (
      <div className="h-20 overflow-hidden rounded-lg bg-surface">
        <img src={product.imageUrl} alt={product.name} className="h-full w-full object-cover" />
      </div>
    );
  }

  const miniSvg: Record<Category, ReactNode> = {
    "欧包/坚果": (
      <svg viewBox="0 0 48 32" className="h-10 w-14">
        <ellipse cx="24" cy="18" rx="18" ry="10" fill="#c4956a" />
        <ellipse cx="24" cy="16" rx="15" ry="8" fill="#d4a574" />
        <path d="M12 14 Q18 10 24 14 Q30 10 36 14" stroke="#8b6239" strokeWidth="1.5" fill="none" />
        <circle cx="10" cy="19" r="1.5" fill="#6b4423" opacity="0.6" />
        <circle cx="38" cy="20" r="1.2" fill="#6b4423" opacity="0.5" />
      </svg>
    ),
    "吐司": (
      <svg viewBox="0 0 36 32" className="h-10 w-11">
        <rect x="6" y="6" width="24" height="24" rx="5" fill="#c4956a" />
        <rect x="9" y="9" width="18" height="18" rx="3" fill="#d4a574" />
        <path d="M10 9 Q18 4 26 9" stroke="#a67c52" strokeWidth="2" fill="none" />
      </svg>
    ),
    "恰巴塔": (
      <svg viewBox="0 0 48 28" className="h-9 w-14">
        <path d="M4 16 Q8 6 20 8 Q32 4 44 10 Q48 14 42 20 Q36 24 24 22 Q12 26 4 20Z" fill="#c4956a" />
        <path d="M6 15 Q10 7 20 9 Q30 6 40 11" stroke="#8b6239" strokeWidth="1" fill="none" />
        <circle cx="16" cy="15" r="1.5" fill="#8b6239" opacity="0.4" />
        <circle cx="30" cy="16" r="1.5" fill="#8b6239" opacity="0.4" />
      </svg>
    ),
    "贝果/海盐卷": (
      <svg viewBox="0 0 32 32" className="h-10 w-10">
        <circle cx="16" cy="16" r="12" fill="#c4956a" />
        <circle cx="16" cy="16" r="7" fill="none" stroke="#d4a574" strokeWidth="5" />
        <circle cx="16" cy="16" r="7" fill="#e8c39e" />
      </svg>
    ),
    "软欧包": (
      <svg viewBox="0 0 44 28" className="h-9 w-13">
        <ellipse cx="22" cy="16" rx="18" ry="9" fill="#c4956a" />
        <ellipse cx="22" cy="14" rx="15" ry="7" fill="#d4a574" />
        <path d="M10 13 Q16 10 22 13 Q28 10 34 13" stroke="#a67c52" strokeWidth="1" fill="none" />
      </svg>
    ),
  };

  return (
    <div className={`relative h-20 overflow-hidden rounded-lg bg-gradient-to-br ${product.imageTone} flex items-center justify-center`}>
      {miniSvg[product.category]}
    </div>
  );
}

function CheckoutPanel({
  batchSale,
  cartItems,
  subtotal,
  shippingFee,
  total,
  stores,
  pickupStore,
  pickupStoreId,
  setPickupStoreId,
  sourceStoreId,
  setSourceStoreId,
  deliveryMethod,
  setDeliveryMethod,
  paymentMethod,
  setPaymentMethod,
  receiver,
  setReceiver,
  phone,
  setPhone,
  address,
  setAddress,
  submitOrder,
  successOrder,
  customer,
  memberMode,
  setMemberMode,
  memberName,
  setMemberName,
  memberPhone,
  setMemberPhone,
  memberPassword,
  setMemberPassword,
  memberMessage,
  submitMember,
  logoutMember,
}: {
  batchSale: BatchSale;
  cartItems: Order["items"];
  subtotal: number;
  shippingFee: number;
  total: number;
  stores: StoreLocation[];
  pickupStore: StoreLocation;
  pickupStoreId: StoreId;
  setPickupStoreId: (storeId: StoreId) => void;
  sourceStoreId: StoreId;
  setSourceStoreId: (storeId: StoreId) => void;
  deliveryMethod: DeliveryMethod;
  setDeliveryMethod: (method: DeliveryMethod) => void;
  paymentMethod: PaymentMethod;
  setPaymentMethod: (method: PaymentMethod) => void;
  receiver: string;
  setReceiver: (value: string) => void;
  phone: string;
  setPhone: (value: string) => void;
  address: string;
  setAddress: (value: string) => void;
  submitOrder: () => void | Promise<void>;
  successOrder: Order | null;
  customer: Customer | null;
  memberMode: "login" | "register";
  setMemberMode: (mode: "login" | "register") => void;
  memberName: string;
  setMemberName: (value: string) => void;
  memberPhone: string;
  setMemberPhone: (value: string) => void;
  memberPassword: string;
  setMemberPassword: (value: string) => void;
  memberMessage: string;
  submitMember: () => void | Promise<void>;
  logoutMember: () => void;
}) {
  const deliveryOptions: { method: DeliveryMethod; icon: LucideIcon; desc: string }[] = [
    { method: "门店自提", icon: Store, desc: pickupStore.address },
    { method: "本地配送", icon: Bike, desc: `满${batchSale.freeShippingThreshold}免运，未满${batchSale.baseShippingFee}元` },
    { method: "顺丰快递", icon: Truck, desc: `满${batchSale.freeShippingThreshold}免运，未满${batchSale.baseShippingFee}元` },
  ];

  const saveOrderImage = (order: Order) => {
    const canvas = document.createElement("canvas");
    canvas.width = 600;
    canvas.height = 800;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    ctx.fillStyle = "#FFFFFF";
    ctx.fillRect(0, 0, 600, 800);

    ctx.textAlign = "center";
    ctx.fillStyle = "#0A0A0A";
    ctx.font = "bold 36px sans-serif";
    ctx.fillText("Mio", 300, 80);

    ctx.strokeStyle = "#E5E5E5";
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(40, 110);
    ctx.lineTo(560, 110);
    ctx.stroke();

    let y = 150;
    ctx.textAlign = "left";
    ctx.font = "14px sans-serif";
    ctx.fillStyle = "#737373";
    ctx.fillText(`订单号: ${order.id}`, 40, y);
    y += 30;
    ctx.fillText(`下单时间: ${order.createdAt}`, 40, y);
    y += 40;

    ctx.font = "16px sans-serif";
    ctx.fillStyle = "#0A0A0A";
    order.items.forEach((item) => {
      ctx.textAlign = "left";
      ctx.fillText(`${item.name}`, 40, y);
      ctx.textAlign = "right";
      ctx.fillText(`¥${item.price} × ${item.qty}`, 560, y);
      y += 30;
    });

    y += 20;
    ctx.strokeStyle = "#E5E5E5";
    ctx.beginPath();
    ctx.moveTo(40, y);
    ctx.lineTo(560, y);
    ctx.stroke();
    y += 40;

    ctx.textAlign = "right";
    ctx.font = "bold 20px sans-serif";
    ctx.fillStyle = "#0A0A0A";
    ctx.fillText(`合计 ¥${order.total}`, 560, y);

    y += 50;
    ctx.textAlign = "left";
    ctx.font = "14px sans-serif";
    ctx.fillStyle = "#737373";
    const storeName = stores.find((s) => s.id === order.pickupStoreId)?.name ?? order.pickupStoreId;
    ctx.fillText(`取货门店: ${storeName}`, 40, y);
    y += 28;
    ctx.fillText(`配送方式: ${order.deliveryMethod}`, 40, y);
    y += 28;
    if (order.pickupCode) {
      ctx.fillText(`取货码: ${order.pickupCode}`, 40, y);
      y += 28;
    }

    y += 40;
    ctx.textAlign = "center";
    ctx.fillStyle = "#C73E1D";
    ctx.font = "16px sans-serif";
    ctx.fillText("感谢预订", 300, y);

    const link = document.createElement("a");
    link.download = `Mio-订单-${order.id}.png`;
    link.href = canvas.toDataURL("image/png");
    link.click();
  };

  return (
    <div className="rounded-lg border border-border bg-white p-5 shadow-soft">
      <div className="flex items-center justify-between">
        <div>
          <p className="text-sm font-semibold text-accent">预订窗口</p>
          <h2 className="mt-1 text-2xl font-semibold">{batchSale.isOpen ? "本轮可下单" : "本轮未开放"}</h2>
        </div>
        <ShoppingBag className="h-6 w-6 text-accent" />
      </div>
      {!batchSale.isOpen && (
        <div className="mt-5 rounded-lg bg-surface p-4 text-sm text-fg/62">
          当前只开放产品浏览。下一轮开炉时，门店会在社群里发送链接。
        </div>
      )}

      <MemberPanel
        customer={customer}
        memberMode={memberMode}
        setMemberMode={setMemberMode}
        memberName={memberName}
        setMemberName={setMemberName}
        memberPhone={memberPhone}
        setMemberPhone={setMemberPhone}
        memberPassword={memberPassword}
        setMemberPassword={setMemberPassword}
        memberMessage={memberMessage}
        submitMember={submitMember}
        logoutMember={logoutMember}
      />

      <div className="mt-5 space-y-3">
        {cartItems.length === 0 ? (
          <p className="rounded-lg bg-white p-4 text-sm text-fg/58">选择面包后，这里会生成预订清单。</p>
        ) : (
          cartItems.map((item) => (
            <div key={item.productId} className="flex items-center justify-between border-b border-border pb-3 text-sm">
              <span>
                {item.name} <span className="text-fg/48">x {item.qty}</span>
              </span>
              <span className="font-semibold">¥{item.qty * item.price}</span>
            </div>
          ))
        )}
      </div>

      <FormLabel label="自提门店" />
      <select
        value={pickupStoreId}
        onChange={(event) => setPickupStoreId(event.target.value as StoreId)}
        className="input-field"
      >
        {stores
          .filter((store) => store.pickupOpen && batchSale.pickupStoreIds.includes(store.id))
          .map((store) => (
            <option key={store.id} value={store.id}>
              {store.name}
            </option>
          ))}
      </select>

      <FormLabel label="来源门店" />
      <select
        value={sourceStoreId}
        onChange={(event) => setSourceStoreId(event.target.value as StoreId)}
        className="input-field"
      >
        {stores.map((store) => (
          <option key={store.id} value={store.id}>
            {store.name} · {store.sourceCode}
          </option>
        ))}
      </select>

      <FormLabel label="取货/配送" />
      <div className="grid gap-2">
        {deliveryOptions.map((option) => {
          const Icon = option.icon;
          const active = deliveryMethod === option.method;
          return (
            <button
              key={option.method}
              type="button"
              onClick={() => setDeliveryMethod(option.method)}
              className={`flex items-center gap-3 rounded-lg border p-3 text-left transition ${
                active ? "border-border bg-fg text-white" : "border-border bg-white hover:bg-surface"
              }`}
            >
              <Icon className="h-5 w-5" />
              <span>
                <span className="block text-sm font-semibold">{option.method}</span>
                <span className={`text-xs ${active ? "text-white/70" : "text-fg/50"}`}>{option.desc}</span>
              </span>
            </button>
          );
        })}
      </div>

      {deliveryMethod !== "门店自提" && (
        <>
          <FormLabel label="配送信息" />
          <div className="grid gap-3">
            <input className="input-field" value={receiver} onChange={(event) => setReceiver(event.target.value)} placeholder="收件人" />
            <input className="input-field" value={phone} onChange={(event) => setPhone(event.target.value)} placeholder="手机号" />
            <textarea className="input-field min-h-20 resize-none" value={address} onChange={(event) => setAddress(event.target.value)} placeholder="详细地址" />
          </div>
        </>
      )}

      <FormLabel label="付款确认" />
      <div className="grid grid-cols-2 gap-2">
        {paymentMethods.map((option) => {
          const Icon = option.icon;
          const active = paymentMethod === option.method;
          return (
            <button
              key={option.method}
              type="button"
              onClick={() => setPaymentMethod(option.method)}
              className={`flex items-center justify-center gap-2 rounded-lg px-3 py-3 text-sm font-semibold transition ${
                active ? "bg-accent text-white" : "bg-surface text-fg/72 hover:bg-surface-hover"
              }`}
            >
              <Icon className="h-4 w-4" />
              {option.method}
            </button>
          );
        })}
      </div>

      <div className="mt-5 space-y-2 border-t border-border pt-5 text-sm">
        <div className="flex justify-between text-fg/58">
          <span>商品小计</span>
          <span>¥{subtotal}</span>
        </div>
        <div className="flex justify-between text-fg/58">
          <span>运费</span>
          <span>{shippingFee === 0 ? "免运费" : `¥${shippingFee}`}</span>
        </div>
        <div className="flex items-center justify-between pt-2">
          <span className="text-fg/58">合计</span>
          <span className="text-3xl font-semibold">¥{total}</span>
        </div>
      </div>
      <button
        type="button"
        onClick={submitOrder}
        disabled={!batchSale.isOpen || cartItems.length === 0 || !customer}
        className="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-full bg-fg px-5 py-3 font-semibold text-white transition hover:bg-accent-hover disabled:cursor-not-allowed disabled:bg-fg/30"
      >
        <BadgeCheck className="h-5 w-5" />
        {batchSale.isOpen ? "生成订购单" : "等待开放"}
      </button>
      {successOrder && (
        <>
          <div className="mt-4 rounded-lg border border-border bg-white p-5">
            <p className="text-base font-semibold text-fg">订货单已生成</p>
            <div className="mt-4 space-y-2 text-sm text-muted">
              <div className="flex justify-between">
                <span>订单号</span>
                <span className="text-fg">{successOrder.id}</span>
              </div>
              {successOrder.items.map((item) => (
                <div key={item.productId} className="flex justify-between">
                  <span>
                    {item.name} <span className="text-muted-light">× {item.qty}</span>
                  </span>
                  <span className="text-fg">¥{item.qty * item.price}</span>
                </div>
              ))}
              <div className="flex justify-between border-t border-border pt-2">
                <span className="font-semibold text-fg">合计</span>
                <span className="font-bold text-fg">¥{successOrder.total}</span>
              </div>
              <div className="pt-1">
                <p>
                  {getStoreName(stores, successOrder.pickupStoreId)} · {successOrder.deliveryMethod}
                </p>
                {successOrder.pickupCode && <p>取货码 {successOrder.pickupCode}</p>}
              </div>
            </div>
            <button
              type="button"
              onClick={() => saveOrderImage(successOrder)}
              className="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-md bg-fg px-4 py-2.5 text-sm font-medium text-white transition hover:bg-fg/90"
            >
              保存订货单图片
            </button>
          </div>
          <PaymentWechatCard batchSale={batchSale} order={successOrder} />
        </>
      )}
    </div>
  );
}

function FormLabel({ label }: { label: string }) {
  return <p className="mb-2 mt-5 text-xs font-semibold uppercase text-fg/48">{label}</p>;
}

function MemberPanel({
  customer,
  memberMode,
  setMemberMode,
  memberName,
  setMemberName,
  memberPhone,
  setMemberPhone,
  memberPassword,
  setMemberPassword,
  memberMessage,
  submitMember,
  logoutMember,
}: {
  customer: Customer | null;
  memberMode: "login" | "register";
  setMemberMode: (mode: "login" | "register") => void;
  memberName: string;
  setMemberName: (value: string) => void;
  memberPhone: string;
  setMemberPhone: (value: string) => void;
  memberPassword: string;
  setMemberPassword: (value: string) => void;
  memberMessage: string;
  submitMember: () => void | Promise<void>;
  logoutMember: () => void;
}) {
  if (customer) {
    return (
      <div className="mt-5 rounded-lg bg-green-50 p-4 text-sm text-green-900">
        <div className="flex items-center justify-between gap-3">
          <span>
            <span className="block font-semibold">{customer.name}</span>
            <span className="text-green-900/68">{customer.phone}</span>
          </span>
          <button type="button" onClick={logoutMember} className="text-xs font-semibold text-green-900/60">
            切换
          </button>
        </div>
      </div>
    );
  }

  return (
    <div className="mt-5 rounded-lg border border-border bg-white p-4">
      <div className="flex items-center justify-between gap-3">
        <p className="font-semibold">会员信息</p>
        <div className="rounded-full bg-white p-1 text-xs font-semibold">
          <button
            type="button"
            onClick={() => setMemberMode("register")}
            className={`rounded-full px-3 py-1 ${memberMode === "register" ? "bg-fg text-white" : "text-fg/58"}`}
          >
            注册
          </button>
          <button
            type="button"
            onClick={() => setMemberMode("login")}
            className={`rounded-full px-3 py-1 ${memberMode === "login" ? "bg-fg text-white" : "text-fg/58"}`}
          >
            登录
          </button>
        </div>
      </div>
      <div className="mt-3 grid gap-3">
        {memberMode === "register" && (
          <input
            className="input-field bg-white"
            value={memberName}
            onChange={(event) => setMemberName(event.target.value)}
            placeholder="姓名"
          />
        )}
        <input
          className="input-field bg-white"
          value={memberPhone}
          onChange={(event) => setMemberPhone(event.target.value)}
          placeholder="手机号"
        />
        <input
          className="input-field bg-white"
          type="password"
          value={memberPassword}
          onChange={(event) => setMemberPassword(event.target.value)}
          placeholder="设置或输入密码"
        />
      </div>
      {memberMessage && <p className="mt-2 text-sm text-accent">{memberMessage}</p>}
      <button
        type="button"
        onClick={submitMember}
        className="mt-3 inline-flex w-full items-center justify-center gap-2 rounded-full bg-fg px-4 py-3 text-sm font-semibold text-white"
      >
        <UserPlus className="h-4 w-4" />
        {memberMode === "register" ? "注册并继续下单" : "登录并继续下单"}
      </button>
    </div>
  );
}

function PaymentWechatCard({ batchSale, order }: { batchSale: BatchSale; order: Order }) {
  const orderText = `订购单 ${order.id}，${order.items
    .map((item) => `${item.name}x${item.qty}`)
    .join("，")}，合计¥${order.total}`;

  return (
    <div className="mt-4 rounded-lg bg-white p-4 text-fg">
      <div className="flex items-start gap-3">
        {batchSale.paymentQrUrl ? (
          <img src={batchSale.paymentQrUrl} alt="Mio Bakery 微信二维码" className="h-24 w-24 rounded-lg object-cover" />
        ) : (
          <div className="qr-box h-24 w-24 shrink-0">
            <QrCode className="h-9 w-9" />
          </div>
        )}
        <div className="min-w-0">
          <p className="font-semibold">添加主理人微信付款确认</p>
          <p className="mt-1 text-sm text-fg/58">微信号 {batchSale.paymentWechatId}</p>
          <p className="mt-2 text-sm leading-6 text-fg/66">{batchSale.paymentInstruction}</p>
        </div>
      </div>
      <div className="mt-3 rounded-lg bg-white p-3 text-xs leading-5 text-fg/58">
        {orderText}
      </div>
    </div>
  );
}

function OrderSummaryCard({ order, stores }: { order: Order; stores: StoreLocation[] }) {
  return (
    <div className="mt-4 rounded-lg bg-white p-4 text-sm">
      <div className="flex flex-wrap items-center justify-between gap-2">
        <p className="font-semibold">订单 {order.id}</p>
        <span className={`rounded-full px-3 py-1 text-xs font-semibold ${statusStyles[order.status]}`}>
          {order.status}
        </span>
      </div>
      <p className="mt-2 text-fg/58">
        取货码 {order.pickupCode} · {getStoreName(stores, order.pickupStoreId)} · ¥{order.total}
      </p>
      <p className="mt-1 text-fg/48">
        {order.customerName || "顾客"} {order.customerPhone || ""} · {order.paymentStatus || "待付款确认"}
      </p>
      <p className="mt-2 leading-6 text-fg/66">
        {order.items.map((item) => `${item.name} x${item.qty}`).join(" / ")}
      </p>
      {order.deliveryMethod !== "门店自提" && (
        <div className="mt-3 rounded-lg bg-white p-3 text-fg/60">
          <p>{order.deliveryMethod} · {order.receiver || "未填收件人"}</p>
          <p className="mt-1">{order.shippingCompany || "待安排配送"} {order.trackingNumber || ""}</p>
          {order.logisticsStatus && <p className="mt-1">{order.logisticsStatus}</p>}
        </div>
      )}
    </div>
  );
}

function HeroProof({
  icon: Icon,
  label,
  desc,
}: {
  icon: LucideIcon;
  label: string;
  desc: string;
}) {
  return (
    <div className="min-w-0">
      <span className="mb-3 flex h-11 w-11 items-center justify-center rounded-full border border-flour/30 bg-white/6">
        <Icon className="h-5 w-5" />
      </span>
      <p className="text-sm font-semibold">{label}</p>
      <p className="mt-1 text-xs leading-5 text-white/60">{desc}</p>
    </div>
  );
}

function TodayBakeCard({
  batchSale,
  products,
  allProducts,
  getAvailable,
}: {
  batchSale: BatchSale;
  products: Product[];
  allProducts: Product[];
  getAvailable: (productId: string) => number;
}) {
  const batches =
    batchSale.ovenBatches.length > 0
      ? batchSale.ovenBatches.map((batch) => ({
          ...batch,
          products: batch.productIds
            .map((productId) => allProducts.find((product) => product.id === productId))
            .filter(Boolean) as Product[],
        }))
      : [
          { id: "batch-am", label: "第一炉", time: "11:30", products: products.slice(0, 3), productIds: [] },
          { id: "batch-pm", label: "第二炉", time: "17:30", products: products.slice(3, 4), productIds: [] },
        ];

  return (
    <div className="w-full rounded-2xl border border-border bg-[#fffaf2] p-5 text-fg shadow-soft sm:p-6 lg:w-[410px]">
      <div className="flex items-center justify-between border-b border-border pb-4">
        <div>
          <p className="text-sm text-fg/52">今日出炉</p>
          <h2 className="mt-1 text-xl font-semibold">开放预订面包单</h2>
        </div>
        <ShoppingBag className="h-5 w-5 text-accent" />
      </div>

      {batches.map((batch, index) => (
        <div key={batch.id} className={`${index === 0 ? "pt-4" : "mt-5 border-t border-border pt-4"}`}>
          <BakeBatchHeader
            time={`${batch.label} ${batch.time}`}
            status={batchSale.isOpen ? (index === 0 ? "已开放" : "即将开始") : "待开放"}
          />
          <div className="mt-3 space-y-3">
            {(batch.products.length > 0 ? batch.products : products.slice(0, 1)).map((product) => (
              <BakeRow key={`${batch.id}-${product.id}`} product={product} available={getAvailable(product.id)} />
            ))}
          </div>
        </div>
      ))}

      <a
        href="#menu"
        className="mt-5 inline-flex w-full items-center justify-center gap-2 border-t border-border pt-5 text-sm font-semibold"
      >
        查看完整面包单
        <ChevronRight className="h-4 w-4" />
      </a>
    </div>
  );
}

function BakeBatchHeader({ time, status }: { time: string; status: string }) {
  return (
    <div className="flex items-center gap-3 text-sm">
      <span className="text-fg/58">{time}</span>
      <span className="rounded-full bg-surface px-3 py-1 text-xs text-fg/62">{status}</span>
    </div>
  );
}

function BakeRow({ product, available }: { product: Product; available: number }) {
  return (
    <div className="grid grid-cols-[48px_minmax(0,1fr)_64px] items-center gap-3 sm:grid-cols-[56px_minmax(0,1fr)_72px]">
      <ProductThumb product={product} />
      <div className="min-w-0">
        <p className="truncate font-semibold">{product.name}</p>
        <p className="mt-1 text-xs text-fg/46">{product.weight}</p>
      </div>
      <div className="text-right">
        <p className="font-semibold">¥{product.price}</p>
        <p className="mt-1 text-xs text-fg/46">剩余 {available}</p>
      </div>
    </div>
  );
}

function ProductThumb({ product }: { product: Product }) {
  if (product.imageUrl) {
    return (
      <div className="h-12 w-14 overflow-hidden rounded-md bg-surface">
        <img src={product.imageUrl} alt={product.name} className="h-full w-full object-cover" />
      </div>
    );
  }

  return (
    <div className={`relative h-12 w-14 overflow-hidden rounded-md bg-gradient-to-br ${product.imageTone}`}>
      <div className="absolute left-1/2 top-1/2 h-7 w-11 -translate-x-1/2 -translate-y-1/2 rounded-[50%] bg-amber-700/75 shadow-[inset_0_5px_0_rgba(255,255,255,.2)]" />
    </div>
  );
}

