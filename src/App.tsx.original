}

function MobileCheckoutBar({
  cartCount,
  total,
  isOpen,
  setOpen,
  checkout,
}: {
  cartCount: number;
  total: number;
  isOpen: boolean;
  setOpen: (open: boolean) => void;
  checkout: ReactNode;
}) {
  return (
    <>
      <div className="fixed inset-x-0 bottom-0 z-50 border-t border-border bg-white/95 p-3 shadow-[0_-8px_32px_rgba(26,18,11,.10)] backdrop-blur-md lg:hidden">
        <button
          type="button"
          onClick={() => setOpen(true)}
          className="flex w-full items-center justify-between rounded-full bg-fg px-6 py-3.5 text-white shadow-card"
        >
          <span className="flex items-center gap-2.5 text-sm font-medium">
            <ShoppingBag className="h-5 w-5" />
            {cartCount > 0 ? `${cartCount} 件面包` : "选择今日面包"}
          </span>
          <span className="text-lg font-semibold">¥{total}</span>
        </button>
      </div>
      {isOpen && (
        <div className="fixed inset-0 z-[60] bg-fg/30 p-3 backdrop-blur-sm lg:hidden">
          <div className="absolute inset-x-0 bottom-0 max-h-[88svh] overflow-y-auto rounded-t-3xl bg-white p-4 shadow-elevated">
            <div className="mb-4 flex items-center justify-between px-1">
              <p className="text-base font-semibold">确认预订</p>
              <button
                type="button"
                onClick={() => setOpen(false)}
                className="flex h-9 w-9 items-center justify-center rounded-full bg-surface transition hover:bg-fg hover:text-white"
                aria-label="关闭结算"
              >
                <X className="h-5 w-5" />
              </button>
            </div>
            {checkout}
          </div>
        </div>
      )}
    </>
  );
}

function AdminPage({
  products,
  setProducts,
  stores,
  setStores,
  batchSale,
  setBatchSale,
  inventory,
  setInventory,
  orders,
  setOrders,
  activeRole,
  navigate,
  setApiError,
}: {
  products: Product[];
  setProducts: Dispatch<SetStateAction<Product[]>>;
  stores: StoreLocation[];
  setStores: Dispatch<SetStateAction<StoreLocation[]>>;
  batchSale: BatchSale;
  setBatchSale: Dispatch<SetStateAction<BatchSale>>;
  inventory: InventoryAllocation;
  setInventory: Dispatch<SetStateAction<InventoryAllocation>>;
  orders: Order[];
  setOrders: Dispatch<SetStateAction<Order[]>>;
  activeRole: RoleId;
  navigate: (route: Route) => void;
  setApiError: (message: string | null) => void;
}) {
  const isHq = activeRole === "hq";
  const activeStoreId = activeRole === "hq" ? "store-a" : (activeRole as StoreId);
  const [newProduct, setNewProduct] = useState({
    name: "",
    category: "欧包/坚果" as Category,
    weight: "280克",
    price: 28,
    description: "",
    ingredients: "",
    imageUrl: "",
    isPublished: true,
    featured: false,
  });
  const [fulfillmentDrafts, setFulfillmentDrafts] = useState<
    Record<string, Pick<Order, "shippingCompany" | "trackingNumber" | "logisticsStatus" | "deliveryNote" | "status">>
  >({});
  const scopedOrders = isHq
    ? orders
    : orders.filter((order) => order.pickupStoreId === activeStoreId || order.sourceStoreId === activeStoreId);
  const todayTotal = scopedOrders.reduce((sum, order) => sum + order.total, 0);
  const pickupCount = scopedOrders.filter((order) => order.deliveryMethod === "门店自提").length;
  const shippingCount = scopedOrders.filter((order) => order.deliveryMethod !== "门店自提").length;
  const productionOrders = scopedOrders.filter(
    (order) => order.status === "待确认" || order.status === "待生产",
  );
  const pickupOrders = scopedOrders.filter(
    (order) => order.deliveryMethod === "门店自提" && order.status !== "已完成",
  );
  const shippingOrders = scopedOrders.filter(
    (order) => order.deliveryMethod !== "门店自提" && order.status !== "已完成",
  );

  const reportError = (error: unknown, fallback: string) => {
    setApiError(error instanceof Error ? error.message : fallback);
  };

  const updateStore = async (storeId: StoreId, field: keyof StoreLocation, value: string | boolean) => {
    if (!isHq) return;
    setStores((current) => current.map((store) => (store.id === storeId ? { ...store, [field]: value } : store)));
    try {
      const updated = await apiRequest<StoreLocation>(`/api/admin/stores/${storeId}`, {
        method: "PATCH",
        body: JSON.stringify({ [field]: value }),
      });
      setStores((current) => current.map((store) => (store.id === storeId ? updated : store)));
      setApiError(null);
    } catch (error) {
      reportError(error, "门店保存失败");
    }
  };

  const updateProduct = async (productId: string, patch: Partial<Product>) => {
    if (!isHq) return;
    setProducts((current) =>
      current.map((product) => (product.id === productId ? { ...product, ...patch } : product)),
    );
    try {
      const updated = await apiRequest<Product>(`/api/admin/products/${productId}`, {
        method: "PATCH",
        body: JSON.stringify(patch),
      });
      setProducts((current) => current.map((product) => (product.id === productId ? updated : product)));
      setApiError(null);
    } catch (error) {
      reportError(error, "商品保存失败");
    }
  };

  const createProduct = async () => {
    if (!isHq || !newProduct.name.trim()) return;
    try {
      const data = await apiRequest<{ product: Product; inventory: InventoryAllocation }>("/api/admin/products", {
        method: "POST",
        body: JSON.stringify({
          ...newProduct,
          name: newProduct.name.trim(),
          price: Number(newProduct.price),
          ingredients: newProduct.ingredients
            .split(/[，,]/)
            .map((item) => item.trim())
            .filter(Boolean),
        }),
      });
      setProducts((current) => [data.product, ...current]);
      setInventory(data.inventory);
      setNewProduct({
        name: "",
        category: "欧包/坚果",
        weight: "280克",
        price: 28,
        description: "",
        ingredients: "",
        imageUrl: "",
        isPublished: true,
        featured: false,
      });
      setApiError(null);
    } catch (error) {
      reportError(error, "新增商品失败");
    }
  };

  const uploadProductImage = async (productId: string, file?: File) => {
    if (!file) return;
    try {
      const imageUrl = await readImageFile(file);
      await updateProduct(productId, { imageUrl });
    } catch (error) {
      reportError(error, "图片上传失败");
    }
  };

  const uploadNewProductImage = async (file?: File) => {
    if (!file) return;
    try {
      const imageUrl = await readImageFile(file);
      setNewProduct((current) => ({ ...current, imageUrl }));
    } catch (error) {
      reportError(error, "图片读取失败");
    }
  };

  const updateBatchSale = async (patch: Partial<BatchSale>) => {
    if (!isHq) return;
    setBatchSale((current) => ({ ...current, ...patch }));
    try {
      const updated = await apiRequest<BatchSale>("/api/admin/batch-sale", {
        method: "PATCH",
        body: JSON.stringify(patch),
      });
      setBatchSale(updated);
      setApiError(null);
    } catch (error) {
      reportError(error, "本轮预订设置保存失败");
    }
  };

  const updateOvenBatch = (batchId: string, patch: Partial<OvenBatch>) => {
    const nextBatches = batchSale.ovenBatches.map((batch) =>
      batch.id === batchId ? { ...batch, ...patch } : batch,
    );
    void updateBatchSale({ ovenBatches: nextBatches });
  };

  const toggleBatchProduct = (batch: OvenBatch, productId: string) => {
    const hasProduct = batch.productIds.includes(productId);
    updateOvenBatch(batch.id, {
      productIds: hasProduct
        ? batch.productIds.filter((id) => id !== productId)
        : [...batch.productIds, productId],
    });
  };

  const addOvenBatch = () => {
    void updateBatchSale({
      ovenBatches: [
        ...batchSale.ovenBatches,
        {
          id: `batch-${Date.now()}`,
          label: `第${batchSale.ovenBatches.length + 1}炉`,
          time: "18:30",
          productIds: [],
        },
      ],
    });
  };

  const removeOvenBatch = (batchId: string) => {
    void updateBatchSale({ ovenBatches: batchSale.ovenBatches.filter((batch) => batch.id !== batchId) });
  };

  const uploadPaymentQr = async (file?: File) => {
    if (!file) return;
    try {
      const paymentQrUrl = await readImageFile(file);
      await updateBatchSale({ paymentQrUrl });
    } catch (error) {
      reportError(error, "微信二维码读取失败");
    }
  };

  const updateStoreStock = async (productId: string, storeId: StoreId, value: number) => {
    if (!isHq) return;
    const allocated = Math.max(0, value);
    setInventory((current) => ({
      ...current,
      [productId]: {
        ...current[productId],
        stores: {
          ...current[productId].stores,
          [storeId]: allocated,
        },
      },
    }));
    try {
      const updated = await apiRequest<InventoryAllocation>("/api/admin/inventory", {
        method: "PATCH",
        body: JSON.stringify({ productId, storeId, allocated }),
      });
      setInventory(updated);
      setApiError(null);
    } catch (error) {
      reportError(error, "库存保存失败");
    }
  };

  const updateOrderStatus = async (orderId: string, status: OrderStatus) => {
    setOrders((current) => current.map((order) => (order.id === orderId ? { ...order, status } : order)));
    try {
      const updated = await apiRequest<Order>(`/api/admin/orders/${orderId}/status`, {
        method: "PATCH",
        body: JSON.stringify({ status }),
      });
      setOrders((current) => current.map((order) => (order.id === orderId ? updated : order)));
      setApiError(null);
    } catch (error) {
      reportError(error, "订单状态保存失败");
    }
  };

  const updateFulfillmentDraft = (order: Order, patch: Partial<Order>) => {
    setFulfillmentDrafts((current) => {
      const existing = current[order.id];
      return {
        ...current,
        [order.id]: {
          ...existing,
          shippingCompany: order.shippingCompany,
          trackingNumber: order.trackingNumber,
          logisticsStatus: order.logisticsStatus,
          deliveryNote: order.deliveryNote,
          status: order.status,
          ...patch,
        },
      };
    });
  };

  const saveFulfillment = async (order: Order) => {
    const draft = fulfillmentDrafts[order.id] ?? order;
    try {
      const updated = await apiRequest<Order>(`/api/admin/orders/${order.id}/fulfillment`, {
        method: "PATCH",
        body: JSON.stringify(draft),
      });
      setOrders((current) => current.map((item) => (item.id === order.id ? updated : item)));
      setFulfillmentDrafts((current) => {
        const next = { ...current };
        delete next[order.id];
        return next;
      });
      setApiError(null);
    } catch (error) {
      reportError(error, "发货信息保存失败");
    }
  };

  const [adminTab, setAdminTab] = useState<"overview" | "orders" | "products" | "settings">("overview");

  const adminTabs = [
    { id: "overview" as const, label: "概览", icon: Home },
    { id: "orders" as const, label: "订单", icon: ClipboardList },
    { id: "products" as const, label: "商品", icon: PackageOpen },
    { id: "settings" as const, label: "设置", icon: Settings2 },
  ];

  return (
    <main className="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <div className="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p className="text-sm font-semibold text-accent">{isHq ? "总部账号" : "门店账号"}</p>
          <h1 className="mt-2 text-4xl font-semibold">运营后台</h1>
          <p className="mt-3 max-w-2xl text-fg/60">
            {isHq
              ? "总部负责商品、开团日、门店改名和库存分配。"
              : "门店只处理本店库存、订单、自提名单和现场收银。"}
          </p>
        </div>
        <button
          type="button"
          onClick={() => navigate("/admin/pos")}
          className="inline-flex items-center justify-center gap-2 rounded-full bg-fg px-5 py-3 font-semibold text-white transition hover:bg-accent-hover"
        >
          <ReceiptText className="h-5 w-5" />
          进入现场收银
        </button>
      </div>

      <div className="mt-6 flex flex-wrap gap-2 border-b border-border pb-1">
        {adminTabs.map((tab) => {
          const Icon = tab.icon;
          const active = adminTab === tab.id;
          return (
            <button
              key={tab.id}
              type="button"
              onClick={() => setAdminTab(tab.id)}
              className={`inline-flex items-center gap-2 rounded-t-lg px-4 py-2.5 text-sm font-semibold transition ${
                active
                  ? "border-b-2 border-border text-fg"
                  : "text-fg/48 hover:text-fg"
              }`}
            >
              <Icon className="h-4 w-4" />
              {tab.label}
            </button>
          );
        })}
      </div>

      {adminTab === "overview" && (
        <>
          <div className="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <Metric label="当前订单" value={`${scopedOrders.length} 单`} icon={ClipboardList} />
        <Metric label="自提订单" value={`${pickupCount} 单`} icon={Store} />
        <Metric label="待发货" value={`${shippingCount} 单`} icon={Truck} />
        <Metric label="订单金额" value={`¥${todayTotal}`} icon={Wallet} />
      </div>

      <section className="mt-10 grid gap-6 lg:grid-cols-2">
        <WorkList
          title="生产清单"
          hint={isHq ? "总部看全部待生产订单" : "本店待生产订单"}
          emptyText="暂无待生产订单"
          orders={productionOrders}
          stores={stores}
        />
        <WorkList
          title="自提名单"
          hint={isHq ? "全部门店未完成自提" : "本店未完成自提"}
          emptyText="暂无待自提订单"
          orders={pickupOrders}
          stores={stores}
        />
      </section>

      <ShippingQueue
        orders={shippingOrders}
        stores={stores}
        drafts={fulfillmentDrafts}
        updateDraft={updateFulfillmentDraft}
        saveFulfillment={saveFulfillment}
      />
        </>
      )}

      {adminTab === "orders" && (
        <section className="mt-8 admin-panel">
          <div className="flex items-center justify-between">
            <h2 className="text-2xl font-semibold">订单管理</h2>
            <span className="text-sm text-fg/48">{isHq ? "全部门店" : "仅本店相关"}</span>
          </div>
          <div className="mt-5 overflow-x-auto">
            <table className="min-w-[980px] w-full text-left text-sm">
              <thead className="text-fg/48">
                <tr>
                  <th className="py-3 font-medium">订单</th>
                  <th className="py-3 font-medium">时间</th>
                  <th className="py-3 font-medium">顾客</th>
                  <th className="py-3 font-medium">商品</th>
                  <th className="py-3 font-medium">类型</th>
                  <th className="py-3 font-medium">自提/配送</th>
                  <th className="py-3 font-medium">付款</th>
                  <th className="py-3 font-medium">状态</th>
                  <th className="py-3 font-medium">归属</th>
                  <th className="py-3 text-right font-medium">金额</th>
                </tr>
              </thead>
              <tbody>
                {scopedOrders.map((order) => (
                  <tr key={order.id} className="border-t border-border">
                    <td className="py-4 font-semibold">{order.id}</td>
                    <td className="py-4 text-fg/56">{order.createdAt}</td>
                    <td className="py-4 text-fg/66">
                      <span className="block font-semibold">{order.customerName || order.receiver || "未登记"}</span>
                      <span className="text-xs text-fg/42">{order.customerPhone || order.phone || "-"}</span>
                    </td>
                    <td className="py-4 text-fg/66">
                      {order.items.map((item) => `${item.name} x${item.qty}`).join(" / ")}
                    </td>
                    <td className="py-4">{order.type === "online" ? "线上" : "收银"}</td>
                    <td className="py-4">{order.deliveryMethod}</td>
                    <td className="py-4 text-fg/56">{order.paymentStatus || "待付款确认"}</td>
                    <td className="py-4">
                      <select
                        value={order.status}
                        onChange={(event) => updateOrderStatus(order.id, event.target.value as OrderStatus)}
                        className={`rounded-full border-0 px-3 py-2 text-xs font-semibold outline-none ${statusStyles[order.status]}`}
                      >
                        {orderStatusOptions.map((status) => (
                          <option key={status} value={status}>
                            {status}
                          </option>
                        ))}
                      </select>
                    </td>
                    <td className="py-4 text-fg/56">{getStoreName(stores, order.pickupStoreId)}</td>
                    <td className="py-4 text-right font-semibold">¥{order.total}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      {adminTab === "products" && (
        <>
          <section className="mt-8 admin-panel">
            <div className="flex items-center justify-between">
              <h2 className="text-2xl font-semibold">商品管理</h2>
              <span className="text-sm text-fg/48">{isHq ? "总部可编辑" : "门店只读"}</span>
            </div>
            <p className="mt-1 text-sm text-fg/48">新增产品、上传图片、修改介绍和上下架都在这里处理。</p>
            {isHq && (
              <NewProductPanel
                product={newProduct}
                setProduct={setNewProduct}
                createProduct={createProduct}
                uploadImage={uploadNewProductImage}
              />
            )}
            <div className="mt-5 space-y-3">
              {products.map((product) => (
                <div key={product.id} className="rounded-lg bg-white p-4">
                  <div className="grid gap-3 sm:grid-cols-[80px_minmax(0,1fr)_auto] sm:items-start">
                    <ProductAdminPreview product={product} />
                    <div className="min-w-0">
                      {isHq ? (
                        <div className="grid gap-2">
                          <input
                            className="input-field bg-white py-2"
                            value={product.name}
                            onChange={(event) => updateProduct(product.id, { name: event.target.value })}
                            aria-label={`${product.name}名称`}
                          />
                          <div className="grid gap-2 sm:grid-cols-3">
                            <select
                              className="input-field bg-white py-2"
                              value={product.category}
                              onChange={(event) => updateProduct(product.id, { category: event.target.value as Category })}
                            >
                              {categories.map((category) => (
                                <option key={category} value={category}>{category}</option>
                              ))}
                            </select>
                            <input
                              className="input-field bg-white py-2"
                              value={product.weight}
                              onChange={(event) => updateProduct(product.id, { weight: event.target.value })}
                              aria-label={`${product.name}克重`}
                            />
                            <input
                              className="input-field bg-white py-2"
                              type="number"
                              value={product.price}
                              onChange={(event) => updateProduct(product.id, { price: Number(event.target.value) })}
                              aria-label={`${product.name}价格`}
                            />
                          </div>
                        </div>
                      ) : (
                        <span>
                          <span className="block font-semibold">{product.name}</span>
                          <span className="text-sm text-fg/48">
                            {product.weight} · ¥{product.price}
                          </span>
                        </span>
                      )}
                    </div>
                    <label className="flex items-center gap-2 text-sm text-fg/62">
                      <input
                        type="checkbox"
                        disabled={!isHq}
                        checked={product.isPublished}
                        onChange={(event) => updateProduct(product.id, { isPublished: event.target.checked })}
                        className="h-4 w-4 accent-cocoa disabled:opacity-40"
                      />
                      上架
                    </label>
                  </div>
                  {isHq && (
                    <div className="mt-3 grid gap-3">
                      <input
                        className="input-field bg-white"
                        value={product.description}
                        onChange={(event) => updateProduct(product.id, { description: event.target.value })}
                        aria-label={`${product.name}介绍`}
                      />
                      <div className="flex flex-wrap items-center gap-3">
                        <label className="inline-flex cursor-pointer items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-fg shadow-sm">
                          <Upload className="h-4 w-4" />
                          上传图片
                          <input
                            type="file"
                            accept="image/*"
                            className="hidden"
                            onChange={(event) => uploadProductImage(product.id, event.target.files?.[0])}
                          />
                        </label>
                        {product.imageUrl && (
                          <button
                            type="button"
                            onClick={() => updateProduct(product.id, { imageUrl: "" })}
                            className="text-sm font-semibold text-fg/52"
                          >
                            移除图片
                          </button>
                        )}
                      </div>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </section>

          <section className="mt-8 admin-panel">
            <div className="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <h2 className="text-2xl font-semibold">库存分配</h2>
                <p className="mt-2 text-sm text-fg/54">
                  总部把中央厨房产量分配到 A/B/C/D，各门店看到自己的可售库存。
                </p>
              </div>
              {!isHq && <span className="rounded-full bg-surface px-4 py-2 text-sm">门店只读</span>}
            </div>
            <div className="mt-5 overflow-x-auto">
              <table className="min-w-[920px] w-full text-left text-sm">
                <thead className="text-fg/48">
                  <tr>
                    <th className="py-3 font-medium">商品</th>
                    <th className="py-3 font-medium">中央库存</th>
                    {stores.map((store) => (
                      <th key={store.id} className="py-3 font-medium">{store.name}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {products.slice(0, isHq ? products.length : 8).map((product) => (
                    <tr key={product.id} className="border-t border-border">
                      <td className="py-3 font-semibold">{product.name}</td>
                      <td className="py-3">{inventory[product.id].centralStock}</td>
                      {stores.map((store) => {
                        const allocated = inventory[product.id].stores[store.id];
                        const sold = inventory[product.id].sold[store.id];
                        return (
                          <td key={store.id} className="py-3">
                            {isHq ? (
                              <input
                                className="input-field w-24 py-2"
                                type="number"
                                value={allocated}
                                onChange={(event) => updateStoreStock(product.id, store.id, Number(event.target.value))}
                              />
                            ) : store.id === activeStoreId ? (
                              <span className="font-semibold">{Math.max(0, allocated - sold)} 剩余</span>
                            ) : (
                              <span className="text-fg/34">-</span>
                            )}
                          </td>
                        );
                      })}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        </>
      )}

      {adminTab === "settings" && isHq && (
        <section className="mt-10 grid gap-8 lg:grid-cols-[.9fr_1.1fr]">
          <div className="admin-panel">
            <h2 className="text-2xl font-semibold">本轮预订设置</h2>
            <div className="mt-5 space-y-4">
              <label className="flex items-center justify-between rounded-lg bg-white p-4">
                <span>
                  <span className="block font-semibold">开放顾客下单</span>
                  <span className="text-sm text-fg/52">关闭后顾客只能浏览产品目录。</span>
                </span>
                <input
                  type="checkbox"
                  checked={batchSale.isOpen}
                  onChange={(event) => updateBatchSale({ isOpen: event.target.checked })}
                  className="h-5 w-5 accent-cocoa"
                />
              </label>
              <input
                className="input-field"
                value={batchSale.deadline}
                onChange={(event) => updateBatchSale({ deadline: event.target.value })}
                aria-label="预订截止时间"
              />
              <input
                className="input-field"
                value={batchSale.ovenBatch}
                onChange={(event) => updateBatchSale({ ovenBatch: event.target.value })}
                aria-label="出炉批次"
              />
              <div className="rounded-lg bg-white p-4">
                <div className="flex items-center justify-between gap-3">
                  <span>
                    <span className="block font-semibold">今日出炉批次</span>
                    <span className="text-sm text-fg/52">设置前台“今日出炉”展示的时间和产品。</span>
                  </span>
                  <button
                    type="button"
                    onClick={addOvenBatch}
                    className="inline-flex items-center gap-2 rounded-full bg-white px-3 py-2 text-xs font-semibold text-fg"
                  >
                    <Plus className="h-3.5 w-3.5" />
                    增加一炉
                  </button>
                </div>
                <div className="mt-4 space-y-4">
                  {batchSale.ovenBatches.map((batch) => (
                    <div key={batch.id} className="rounded-lg border border-border bg-white p-3">
                      <div className="grid gap-2 sm:grid-cols-[1fr_1fr_auto]">
                        <input
                          className="input-field py-2"
                          value={batch.label}
                          onChange={(event) => updateOvenBatch(batch.id, { label: event.target.value })}
                          aria-label="批次名称"
                        />
                        <input
                          className="input-field py-2"
                          value={batch.time}
                          onChange={(event) => updateOvenBatch(batch.id, { time: event.target.value })}
                          aria-label="出炉时间"
                        />
                        <button
                          type="button"
                          onClick={() => removeOvenBatch(batch.id)}
                          className="rounded-full bg-surface px-3 py-2 text-xs font-semibold text-fg/62"
                        >
                          删除
                        </button>
                      </div>
                      <div className="mt-3 flex max-h-32 flex-wrap gap-2 overflow-y-auto">
                        {products.map((product) => (
                          <button
                            key={product.id}
                            type="button"
                            onClick={() => toggleBatchProduct(batch, product.id)}
                            className={`rounded-full px-3 py-1 text-xs font-semibold ${
                              batch.productIds.includes(product.id)
                                ? "bg-fg text-white"
                                : "bg-surface text-fg/58"
                            }`}
                          >
                            {product.name}
                          </button>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
              <div className="rounded-lg bg-white p-4">
                <p className="font-semibold">私域付款设置</p>
                <div className="mt-3 grid gap-3">
                  <input
                    className="input-field bg-white"
                    value={batchSale.paymentWechatId}
                    onChange={(event) => updateBatchSale({ paymentWechatId: event.target.value })}
                    aria-label="主理人微信号"
                  />
                  <textarea
                    className="input-field min-h-20 resize-none bg-white"
                    value={batchSale.paymentInstruction}
                    onChange={(event) => updateBatchSale({ paymentInstruction: event.target.value })}
                    aria-label="付款说明"
                  />
                  <div className="flex flex-wrap items-center gap-3">
                    <label className="inline-flex cursor-pointer items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-fg shadow-sm">
                      <QrCode className="h-4 w-4" />
                      上传微信二维码
                      <input
                        type="file"
                        accept="image/*"
                        className="hidden"
                        onChange={(event) => uploadPaymentQr(event.target.files?.[0])}
                      />
                    </label>
                    {batchSale.paymentQrUrl && (
                      <button
                        type="button"
                        onClick={() => updateBatchSale({ paymentQrUrl: "" })}
                        className="text-sm font-semibold text-fg/52"
                      >
                        移除二维码
                      </button>
                    )}
                  </div>
                </div>
              </div>
              <div className="grid gap-3 sm:grid-cols-2">
                <label className="text-sm">
                  <span className="mb-2 block text-fg/52">免运门槛</span>
                  <input
                    className="input-field"
                    type="number"
                    value={batchSale.freeShippingThreshold}
                    onChange={(event) =>
                      updateBatchSale({ freeShippingThreshold: Number(event.target.value) })
                    }
                  />
                </label>
                <label className="text-sm">
                  <span className="mb-2 block text-fg/52">基础运费</span>
                  <input
                    className="input-field"
                    type="number"
                    value={batchSale.baseShippingFee}
                    onChange={(event) =>
                      updateBatchSale({ baseShippingFee: Number(event.target.value) })
                    }
                  />
                </label>
              </div>
            </div>
          </div>

          <div className="admin-panel">
            <h2 className="text-2xl font-semibold">门店与账号</h2>
            <div className="mt-5 grid gap-3">
              {stores.map((store) => (
                <div key={store.id} className="rounded-lg bg-white p-4">
                  <div className="flex items-center justify-between gap-3">
                    <span className="text-xs font-semibold text-fg/44">{store.id}</span>
                    <span className="rounded-full bg-white px-3 py-1 text-xs text-fg/56">
                      {store.role === "central" ? "中央厨房" : "自提点"}
                    </span>
                  </div>
                  <div className="mt-3 grid gap-3 md:grid-cols-[1fr_1.2fr_auto] md:items-center">
                    <input
                      className="input-field"
                      value={store.name}
                      onChange={(event) => updateStore(store.id, "name", event.target.value)}
                      aria-label="门店名称"
                    />
                    <input
                      className="input-field"
                      value={store.address}
                      onChange={(event) => updateStore(store.id, "address", event.target.value)}
                      aria-label="门店地址"
                    />
                    <label className="flex items-center gap-2 text-sm text-fg/62">
                      <input
                        type="checkbox"
                        checked={store.pickupOpen}
                        onChange={(event) => updateStore(store.id, "pickupOpen", event.target.checked)}
                        className="h-4 w-4 accent-cocoa"
                      />
                      开放自提
                    </label>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

    </main>
  );
}

function WorkList({
  title,
  hint,
  emptyText,
  orders,
  stores,
}: {
  title: string;
  hint: string;
  emptyText: string;
  orders: Order[];
  stores: StoreLocation[];
}) {
  return (
    <div className="admin-panel">
      <div className="flex items-start justify-between gap-4">
        <div>
          <h2 className="text-2xl font-semibold">{title}</h2>
          <p className="mt-1 text-sm text-fg/48">{hint}</p>
        </div>
        <span className="rounded-full bg-surface px-3 py-1 text-xs font-semibold text-fg/58">
          {orders.length} 单
        </span>
      </div>
      <div className="mt-5 space-y-3">
        {orders.length === 0 ? (
          <p className="rounded-lg bg-white p-4 text-sm text-fg/54">{emptyText}</p>
        ) : (
          orders.slice(0, 6).map((order) => (
            <div key={order.id} className="rounded-lg border border-border bg-white p-4">
              <div className="flex flex-wrap items-center justify-between gap-2">
                <p className="font-semibold">
                  {order.id}
                  {order.pickupCode ? <span className="ml-2 text-fg/48">取货码 {order.pickupCode}</span> : null}
                </p>
                <span className={`rounded-full px-3 py-1 text-xs font-semibold ${statusStyles[order.status]}`}>
                  {order.status}
                </span>
              </div>
              <p className="mt-2 text-sm leading-6 text-fg/64">
                {order.items.map((item) => `${item.name} x${item.qty}`).join(" / ")}
              </p>
              <p className="mt-2 text-xs text-fg/42">
                {getStoreName(stores, order.pickupStoreId)} · {order.deliveryMethod} · {order.createdAt}
              </p>
            </div>
          ))
        )}
      </div>
    </div>
  );
}

function ShippingQueue({
  orders,
  stores,
  drafts,
  updateDraft,
  saveFulfillment,
}: {
  orders: Order[];
  stores: StoreLocation[];
  drafts: Record<string, Pick<Order, "shippingCompany" | "trackingNumber" | "logisticsStatus" | "deliveryNote" | "status">>;
  updateDraft: (order: Order, patch: Partial<Order>) => void;
  saveFulfillment: (order: Order) => void;
}) {
  return (
    <section className="mt-10 admin-panel">
      <div className="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 className="text-2xl font-semibold">发货队列</h2>
          <p className="mt-1 text-sm text-fg/48">顺丰快递和本地配送订单在这里填写运单号、跑腿备注和物流状态。</p>
        </div>
        <span className="rounded-full bg-surface px-3 py-1 text-xs font-semibold text-fg/58">{orders.length} 单待处理</span>
      </div>
      <div className="mt-5 grid gap-4 lg:grid-cols-2">
        {orders.length === 0 ? (
          <p className="rounded-lg bg-white p-4 text-sm text-fg/54 lg:col-span-2">暂无需要发货或配送的订单。</p>
        ) : (
          orders.map((order) => {
            const draft = { ...order, ...(drafts[order.id] ?? {}) };
            return (
              <div key={order.id} className="rounded-lg border border-border bg-white p-4">
                <div className="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <p className="font-semibold">{order.id}</p>
                    <p className="mt-1 text-sm text-fg/52">
                      {order.deliveryMethod} · {getStoreName(stores, order.pickupStoreId)} · ¥{order.total}
                    </p>
                  </div>
                  <span className={`rounded-full px-3 py-1 text-xs font-semibold ${statusStyles[order.status]}`}>
                    {order.status}
                  </span>
                </div>
                <p className="mt-3 text-sm leading-6 text-fg/66">
                  {order.items.map((item) => `${item.name} x${item.qty}`).join(" / ")}
                </p>
                <div className="mt-4 grid gap-3 sm:grid-cols-2">
                  <input
                    className="input-field bg-white"
                    value={draft.shippingCompany ?? ""}
                    onChange={(event) => updateDraft(order, { shippingCompany: event.target.value })}
                    placeholder="快递/跑腿公司"
                  />
                  <input
                    className="input-field bg-white"
                    value={draft.trackingNumber ?? ""}
                    onChange={(event) => updateDraft(order, { trackingNumber: event.target.value })}
                    placeholder="运单号/跑腿单号"
                  />
                  <input
                    className="input-field bg-white sm:col-span-2"
                    value={draft.logisticsStatus ?? ""}
                    onChange={(event) => updateDraft(order, { logisticsStatus: event.target.value })}
                    placeholder="物流状态，例如：已通知跑腿，预计 17:30 送达"
                  />
                  <textarea
                    className="input-field min-h-20 resize-none bg-white sm:col-span-2"
                    value={draft.deliveryNote ?? ""}
                    onChange={(event) => updateDraft(order, { deliveryNote: event.target.value })}
                    placeholder="配送备注"
                  />
                </div>
                <div className="mt-4 flex flex-wrap gap-2">
                  <button
                    type="button"
                    onClick={() => {
                      updateDraft(order, { status: "已发货", logisticsStatus: draft.logisticsStatus || "已发货" });
                      void saveFulfillment({ ...order, ...draft, status: "已发货", logisticsStatus: draft.logisticsStatus || "已发货" });
                    }}
                    className="inline-flex items-center gap-2 rounded-full bg-fg px-4 py-2 text-sm font-semibold text-white"
                  >
                    <Truck className="h-4 w-4" />
                    标记已发货
                  </button>
                  <button
                    type="button"
                    onClick={() => void saveFulfillment(order)}
                    className="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-fg shadow-sm"
                  >
                    <BadgeCheck className="h-4 w-4" />
                    保存
                  </button>
                </div>
              </div>
            );
          })
        )}
      </div>
    </section>
  );
}

function NewProductPanel({
  product,
  setProduct,
  createProduct,
  uploadImage,
}: {
  product: {
    name: string;
    category: Category;
    weight: string;
    price: number;
    description: string;
    ingredients: string;
    imageUrl: string;
    isPublished: boolean;
    featured: boolean;
  };
  setProduct: Dispatch<SetStateAction<{
    name: string;
    category: Category;
    weight: string;
    price: number;
    description: string;
    ingredients: string;
    imageUrl: string;
    isPublished: boolean;
    featured: boolean;
  }>>;
  createProduct: () => void;
  uploadImage: (file?: File) => void;
}) {
  return (
    <div className="mt-5 rounded-lg border border-dashed border-border bg-white p-4">
      <div className="flex items-center gap-2">
        <PackageOpen className="h-5 w-5 text-accent" />
        <p className="font-semibold">新增产品</p>
      </div>
      <div className="mt-4 grid gap-3">
        <input
          className="input-field bg-white"
          value={product.name}
          onChange={(event) => setProduct((current) => ({ ...current, name: event.target.value }))}
          placeholder="产品名称"
        />
        <div className="grid gap-3 sm:grid-cols-3">
          <select
            className="input-field bg-white"
            value={product.category}
            onChange={(event) => setProduct((current) => ({ ...current, category: event.target.value as Category }))}
          >
            {categories.map((category) => (
              <option key={category} value={category}>{category}</option>
            ))}
          </select>
          <input
            className="input-field bg-white"
            value={product.weight}
            onChange={(event) => setProduct((current) => ({ ...current, weight: event.target.value }))}
            placeholder="克重"
          />
          <input
            className="input-field bg-white"
            type="number"
            value={product.price}
            onChange={(event) => setProduct((current) => ({ ...current, price: Number(event.target.value) }))}
            placeholder="价格"
          />
        </div>
        <input
          className="input-field bg-white"
          value={product.ingredients}
          onChange={(event) => setProduct((current) => ({ ...current, ingredients: event.target.value }))}
          placeholder="配料，用逗号分隔"
        />
        <textarea
          className="input-field min-h-20 resize-none bg-white"
          value={product.description}
          onChange={(event) => setProduct((current) => ({ ...current, description: event.target.value }))}
          placeholder="产品介绍"
        />
        <div className="flex flex-wrap items-center gap-3">
          <label className="inline-flex cursor-pointer items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-fg shadow-sm">
            <Camera className="h-4 w-4" />
            选择图片
            <input
              type="file"
              accept="image/*"
              className="hidden"
              onChange={(event) => uploadImage(event.target.files?.[0])}
            />
          </label>
          <label className="flex items-center gap-2 text-sm text-fg/62">
            <input
              type="checkbox"
              checked={product.isPublished}
              onChange={(event) => setProduct((current) => ({ ...current, isPublished: event.target.checked }))}
              className="h-4 w-4 accent-cocoa"
            />
            新品直接上架
          </label>
          {product.imageUrl && <span className="text-sm text-green-800">图片已选择</span>}
        </div>
        <button
          type="button"
          onClick={createProduct}
          className="inline-flex items-center justify-center gap-2 rounded-full bg-fg px-5 py-3 text-sm font-semibold text-white"
        >
          <Plus className="h-4 w-4" />
          添加到商品库
        </button>
      </div>
    </div>
  );
}

function Metric({ label, value, icon: Icon }: { label: string; value: string; icon: LucideIcon }) {
  return (
    <div className="rounded-lg border border-border bg-white p-5 shadow-sm">
      <div className="flex items-center justify-between">
        <span className="text-sm text-fg/48">{label}</span>
        <Icon className="h-5 w-5 text-accent" />
      </div>
      <p className="mt-3 text-3xl font-semibold">{value}</p>
    </div>
  );
}

function PosPage({
  products,
  stores,
  inventory,
  activeRole,
  createOrder,
  navigate,
}: {
  products: Product[];
  stores: StoreLocation[];
  inventory: InventoryAllocation;
  activeRole: RoleId;
  createOrder: (order: Order) => Promise<Order | null>;
  navigate: (route: Route) => void;
}) {
  const storeId = activeRole === "hq" ? "store-a" : (activeRole as StoreId);
  const store = stores.find((item) => item.id === storeId) ?? stores[0];
  const [cart, setCart] = useState<Record<string, number>>({ "salt-roll": 2 });
  const [paymentMethod, setPaymentMethod] = useState<PaymentMethod>("现金");
  const [lastOrder, setLastOrder] = useState<Order | null>(null);
  const quickProducts = products.filter((product) => product.isPublished).slice(0, 9);
  const cartItems = useMemo(
    () =>
      Object.entries(cart)
        .map(([productId, qty]) => {
          const product = products.find((item) => item.id === productId);
          return product && qty > 0
            ? { productId, name: product.name, qty, price: product.price }
            : null;
        })
        .filter(Boolean) as Order["items"],
    [cart, products],
  );
  const subtotal = cartItems.reduce((sum, item) => sum + item.qty * item.price, 0);

  const availableForStore = (productId: string) => {
    const allocation = inventory[productId];
    if (!allocation) return 0;
    return Math.max(0, allocation.stores[storeId] - allocation.sold[storeId]);
  };

  const updateCart = (productId: string, delta: number) => {
    const available = availableForStore(productId);
    setCart((current) => {
      const nextQty = Math.max(0, Math.min(available, (current[productId] ?? 0) + delta));
      const next = { ...current, [productId]: nextQty };
      if (nextQty === 0) delete next[productId];
      return next;
    });
  };

  const checkout = async () => {
    if (cartItems.length === 0) return;
    const order: Order = {
      id: "",
      type: "pos",
      items: cartItems,
      subtotal,
      shippingFee: 0,
      total: subtotal,
      deliveryMethod: "门店自提",
      paymentMethod,
      status: "已完成",
      sourceStoreId: storeId,
      pickupStoreId: storeId,
      createdAt: "刚刚",
    };
    const savedOrder = await createOrder(order);
    if (savedOrder) {
      setLastOrder(savedOrder);
      setCart({});
    }
  };

  return (
    <main className="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <div className="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p className="text-sm font-semibold text-accent">{store.name}</p>
          <h1 className="mt-2 text-4xl font-semibold">现场收银台</h1>
          <p className="mt-3 max-w-2xl text-fg/60">
            门店现场拿货结账，订单归属到当前门店账号。
          </p>
        </div>
        <button
          type="button"
          onClick={() => navigate("/admin")}
          className="inline-flex items-center justify-center gap-2 rounded-full bg-white px-5 py-3 font-semibold text-fg shadow-sm transition hover:bg-surface"
        >
          <ChevronRight className="h-5 w-5 rotate-180" />
          返回后台
        </button>
      </div>

      <section className="mt-8 grid gap-8 lg:grid-cols-[1fr_380px]">
        <div className="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {quickProducts.map((product) => (
            <button
              key={product.id}
              type="button"
              onClick={() => updateCart(product.id, 1)}
              className="group rounded-lg border border-border bg-white text-left shadow-sm transition hover:-translate-y-1 hover:shadow-soft"
            >
              <ProductVisual product={product} />
              <div className="p-5">
                <div className="flex items-start justify-between gap-3">
                  <span>
                    <span className="block text-lg font-semibold">{product.name}</span>
                    <span className="mt-1 block text-sm text-fg/48">
                      {product.weight} · 本店剩余 {availableForStore(product.id)}
                    </span>
                  </span>
                  <span className="text-xl font-semibold text-accent">¥{product.price}</span>
                </div>
                <span className="mt-5 inline-flex items-center gap-2 rounded-full bg-fg px-4 py-2 text-sm font-semibold text-white">
                  <Plus className="h-4 w-4" />
                  加到收银单
                </span>
              </div>
            </button>
          ))}
        </div>

        <aside className="rounded-lg border border-border bg-white p-5 shadow-soft lg:sticky lg:top-24 lg:self-start">
          <div className="flex items-center justify-between">
            <h2 className="text-2xl font-semibold">当前收银单</h2>
            <ReceiptText className="h-6 w-6 text-accent" />
          </div>
          <div className="mt-5 space-y-3">
            {cartItems.length === 0 ? (
              <p className="rounded-lg bg-surface p-4 text-sm text-fg/58">选择商品后生成收银单。</p>
            ) : (
              cartItems.map((item) => (
                <div key={item.productId} className="flex items-center justify-between border-b border-border pb-3">
                  <div>
                    <p className="font-semibold">{item.name}</p>
                    <p className="text-sm text-fg/48">¥{item.price} x {item.qty}</p>
                  </div>
                  <div className="flex items-center gap-2">
                    <button type="button" onClick={() => updateCart(item.productId, -1)} className="counter-button" aria-label="减少">
                      <Minus className="h-4 w-4" />
                    </button>
                    <button type="button" onClick={() => updateCart(item.productId, 1)} className="counter-button" aria-label="增加">
                      <Plus className="h-4 w-4" />
                    </button>
                  </div>
                </div>
              ))
            )}
          </div>

          <FormLabel label="现场收款" />
          <div className="grid grid-cols-2 gap-2">
            {paymentMethods.map((option) => {
              const Icon = option.icon;
              const active = paymentMethod === option.method;
              return (
                <button
                  key={option.method}
                  type="button"
                  onClick={() => setPaymentMethod(option.method)}
                  className={`flex items-center justify-center gap-2 rounded-lg px-3 py-3 text-sm font-semibold ${
                    active ? "bg-accent text-white" : "bg-surface text-fg/70"
                  }`}
                >
                  <Icon className="h-4 w-4" />
                  {option.method}
                </button>
              );
            })}
          </div>

          <div className="mt-6 flex items-center justify-between border-t border-border pt-5">
            <span className="text-sm text-fg/58">应收</span>
            <span className="text-4xl font-semibold">¥{subtotal}</span>
          </div>
          <button
            type="button"
            onClick={checkout}
            disabled={cartItems.length === 0}
            className="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-full bg-fg px-5 py-3 font-semibold text-white transition hover:bg-accent-hover disabled:cursor-not-allowed disabled:bg-fg/30"
          >
            <BadgeCheck className="h-5 w-5" />
            完成收银
          </button>
          {lastOrder && (
            <div className="mt-4 rounded-lg bg-green-50 p-4 text-sm text-green-900">
              {lastOrder.id} 已完成，归属 {store.name}
              {lastOrder.pickupCode ? `，取货码 ${lastOrder.pickupCode}` : ""}。
            </div>
          )}
        </aside>
      </section>
    </main>
  );
}

function getStoreName(stores: StoreLocation[], storeId: StoreId) {
  return stores.find((store) => store.id === storeId)?.name ?? storeId;
}

export default App;
