        {items.map((item) => {
          const Icon = item.icon;
          return (
            <a
              key={item.label}
              href={item.href}
              className="group rounded-2xl bg-white p-6 shadow-card transition duration-500 hover:-translate-y-1 hover:shadow-elevated"
