const defaultStoreStock: Record<StoreId, number> = {
  "store-a": 12,
  "store-b": 8,
  "store-c": 8,
  "store-d": 6,
};

const initialInventory: InventoryAllocation = Object.fromEntries(
  initialProducts.map((product, index) => {
    const total = 32 + (index % 5) * 6;
    return [
      product.id,
      {
        centralStock: total,
        stores: {
          "store-a": Math.min(total, defaultStoreStock["store-a"] + (index % 3)),
          "store-b": Math.min(total, defaultStoreStock["store-b"] + (index % 2)),
          "store-c": Math.min(total, defaultStoreStock["store-c"]),
          "store-d": Math.min(total, defaultStoreStock["store-d"] + (index % 2)),
        },
        sold: {
          "store-a": index % 4,
          "store-b": index % 3,
          "store-c": index % 2,
          "store-d": index % 3 === 0 ? 1 : 0,
        },
      },
    ];
  }),
) as InventoryAllocation;

