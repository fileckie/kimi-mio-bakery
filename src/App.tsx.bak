        <div>
          <h2 className="text-2xl font-semibold">{title}</h2>
          <p className="mt-1 text-sm text-cocoa/48">{hint}</p>
        </div>
        <span className="rounded-full bg-oat px-3 py-1 text-xs font-semibold text-cocoa/58">
          {orders.length} 单
        </span>
      </div>
      <div className="mt-5 space-y-3">
        {orders.length === 0 ? (
          <p className="rounded-lg bg-flour p-4 text-sm text-cocoa/54">{emptyText}</p>
        ) : (
          orders.slice(0, 6).map((order) => (
            <div key={order.id} className="rounded-lg border border-cocoa/8 bg-flour p-4">
              <div className="flex flex-wrap items-center justify-between gap-2">
                <p className="font-semibold">
                  {order.id}
                  {order.pickupCode ? <span className="ml-2 text-cocoa/48">取货码 {order.pickupCode}</span> : null}
                </p>
                <span className={`rounded-full px-3 py-1 text-xs font-semibold ${statusStyles[order.status]}`}>
                  {order.status}
                </span>
              </div>
              <p className="mt-2 text-sm leading-6 text-cocoa/64">
                {order.items.map((item) => `${item.name} x${item.qty}`).join(" / ")}
              </p>
              <p className="mt-2 text-xs text-cocoa/42">
                {getStoreName(stores, order.pickupStoreId)} · {order.deliveryMethod} · {order.createdAt}
              </p>
            </div>
          ))
        )}
      </div>
    </div>
  );
}

function ShippingQueue({
  orders,
  stores,
  drafts,
  updateDraft,
  saveFulfillment,
}: {
  orders: Order[];
  stores: StoreLocation[];
  drafts: Record<string, Pick<Order, "shippingCompany" | "trackingNumber" | "logisticsStatus" | "deliveryNote" | "status">>;
  updateDraft: (order: Order, patch: Partial<Order>) => void;
  saveFulfillment: (order: Order) => void;
}) {
  return (
    <section className="mt-10 admin-panel">
      <div className="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 className="text-2xl font-semibold">发货队列</h2>
          <p className="mt-1 text-sm text-cocoa/48">顺丰快递和本地配送订单在这里填写运单号、跑腿备注和物流状态。</p>
        </div>
        <span className="rounded-full bg-oat px-3 py-1 text-xs font-semibold text-cocoa/58">{orders.length} 单待处理</span>
      </div>
      <div className="mt-5 grid gap-4 lg:grid-cols-2">
        {orders.length === 0 ? (
          <p className="rounded-lg bg-flour p-4 text-sm text-cocoa/54 lg:col-span-2">暂无需要发货或配送的订单。</p>
        ) : (
          orders.map((order) => {
            const draft = { ...order, ...(drafts[order.id] ?? {}) };
            return (
              <div key={order.id} className="rounded-lg border border-cocoa/8 bg-flour p-4">
                <div className="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <p className="font-semibold">{order.id}</p>
                    <p className="mt-1 text-sm text-cocoa/52">
                      {order.deliveryMethod} · {getStoreName(stores, order.pickupStoreId)} · ¥{order.total}
                    </p>
                  </div>
                  <span className={`rounded-full px-3 py-1 text-xs font-semibold ${statusStyles[order.status]}`}>
                    {order.status}
                  </span>
                </div>
                <p className="mt-3 text-sm leading-6 text-cocoa/66">
                  {order.items.map((item) => `${item.name} x${item.qty}`).join(" / ")}
                </p>
                <div className="mt-4 grid gap-3 sm:grid-cols-2">
                  <input
                    className="input-field bg-white"
                    value={draft.shippingCompany ?? ""}
                    onChange={(event) => updateDraft(order, { shippingCompany: event.target.value })}
                    placeholder="快递/跑腿公司"
                  />
                  <input
                    className="input-field bg-white"
                    value={draft.trackingNumber ?? ""}
                    onChange={(event) => updateDraft(order, { trackingNumber: event.target.value })}
                    placeholder="运单号/跑腿单号"
                  />
                  <input
                    className="input-field bg-white sm:col-span-2"
                    value={draft.logisticsStatus ?? ""}
                    onChange={(event) => updateDraft(order, { logisticsStatus: event.target.value })}
                    placeholder="物流状态，例如：已通知跑腿，预计 17:30 送达"
                  />
                  <textarea
                    className="input-field min-h-20 resize-none bg-white sm:col-span-2"
                    value={draft.deliveryNote ?? ""}
                    onChange={(event) => updateDraft(order, { deliveryNote: event.target.value })}
                    placeholder="配送备注"
                  />
                </div>
                <div className="mt-4 flex flex-wrap gap-2">
                  <button
                    type="button"
                    onClick={() => {
                      updateDraft(order, { status: "已发货", logisticsStatus: draft.logisticsStatus || "已发货" });
                      void saveFulfillment({ ...order, ...draft, status: "已发货", logisticsStatus: draft.logisticsStatus || "已发货" });
                    }}
                    className="inline-flex items-center gap-2 rounded-full bg-cocoa px-4 py-2 text-sm font-semibold text-flour"
                  >
                    <Truck className="h-4 w-4" />
                    标记已发货
                  </button>
                  <button
                    type="button"
                    onClick={() => void saveFulfillment(order)}
                    className="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-cocoa shadow-sm"
                  >
                    <BadgeCheck className="h-4 w-4" />
                    保存
                  </button>
                </div>
              </div>
            );
          })
        )}
      </div>
    </section>
  );
}

