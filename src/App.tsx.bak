        <input
          className="input-field bg-white"
          value={product.ingredients}
          onChange={(event) => setProduct((current) => ({ ...current, ingredients: event.target.value }))}
          placeholder="配料，用逗号分隔"
        />
        <textarea
          className="input-field min-h-20 resize-none bg-white"
          value={product.description}
          onChange={(event) => setProduct((current) => ({ ...current, description: event.target.value }))}
          placeholder="产品介绍"
        />
        <div className="flex flex-wrap items-center gap-3">
          <label className="inline-flex cursor-pointer items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-cocoa shadow-sm">
            <Camera className="h-4 w-4" />
            选择图片
            <input
              type="file"
              accept="image/*"
              className="hidden"
              onChange={(event) => uploadImage(event.target.files?.[0])}
            />
          </label>
          <label className="flex items-center gap-2 text-sm text-cocoa/62">
            <input
              type="checkbox"
              checked={product.isPublished}
              onChange={(event) => setProduct((current) => ({ ...current, isPublished: event.target.checked }))}
              className="h-4 w-4 accent-cocoa"
            />
            新品直接上架
          </label>
          {product.imageUrl && <span className="text-sm text-green-800">图片已选择</span>}
        </div>
        <button
          type="button"
          onClick={createProduct}
          className="inline-flex items-center justify-center gap-2 rounded-full bg-cocoa px-5 py-3 text-sm font-semibold text-flour"
        >
          <Plus className="h-4 w-4" />
          添加到商品库
        </button>
      </div>
    </div>
  );
}

function Metric({ label, value, icon: Icon }: { label: string; value: string; icon: LucideIcon }) {
  return (
    <div className="rounded-lg border border-cocoa/10 bg-white p-5 shadow-sm">
      <div className="flex items-center justify-between">
        <span className="text-sm text-cocoa/48">{label}</span>
        <Icon className="h-5 w-5 text-crust" />
      </div>
      <p className="mt-3 text-3xl font-semibold">{value}</p>
    </div>
  );
}

function PosPage({
  products,
  stores,
  inventory,
  activeRole,
  createOrder,
  navigate,
}: {
  products: Product[];
  stores: StoreLocation[];
  inventory: InventoryAllocation;
  activeRole: RoleId;
  createOrder: (order: Order) => Promise<Order | null>;
  navigate: (route: Route) => void;
}) {
  const storeId = activeRole === "hq" ? "store-a" : (activeRole as StoreId);
  const store = stores.find((item) => item.id === storeId) ?? stores[0];
  const [cart, setCart] = useState<Record<string, number>>({ "salt-roll": 2 });
  const [paymentMethod, setPaymentMethod] = useState<PaymentMethod>("现金");
  const [lastOrder, setLastOrder] = useState<Order | null>(null);
  const quickProducts = products.filter((product) => product.isPublished).slice(0, 9);
  const cartItems = useMemo(
    () =>
      Object.entries(cart)
        .map(([productId, qty]) => {
          const product = products.find((item) => item.id === productId);
          return product && qty > 0
            ? { productId, name: product.name, qty, price: product.price }
            : null;
        })
        .filter(Boolean) as Order["items"],
    [cart, products],
  );
  const subtotal = cartItems.reduce((sum, item) => sum + item.qty * item.price, 0);

  const availableForStore = (productId: string) => {
    const allocation = inventory[productId];
    if (!allocation) return 0;
    return Math.max(0, allocation.stores[storeId] - allocation.sold[storeId]);
  };

  const updateCart = (productId: string, delta: number) => {
    const available = availableForStore(productId);
    setCart((current) => {
      const nextQty = Math.max(0, Math.min(available, (current[productId] ?? 0) + delta));
      const next = { ...current, [productId]: nextQty };
      if (nextQty === 0) delete next[productId];
      return next;
    });
  };

  const checkout = async () => {
    if (cartItems.length === 0) return;
    const order: Order = {
      id: "",
      type: "pos",
      items: cartItems,
      subtotal,
      shippingFee: 0,
      total: subtotal,
      deliveryMethod: "门店自提",
      paymentMethod,
      status: "已完成",
      sourceStoreId: storeId,
      pickupStoreId: storeId,
      createdAt: "刚刚",
    };
    const savedOrder = await createOrder(order);
    if (savedOrder) {
      setLastOrder(savedOrder);
      setCart({});
    }
  };

  return (
    <main className="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <div className="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p className="text-sm font-semibold text-ember">{store.name}</p>
          <h1 className="mt-2 text-4xl font-semibold">现场收银台</h1>
          <p className="mt-3 max-w-2xl text-cocoa/60">
            门店现场拿货结账，订单归属到当前门店账号。
          </p>
        </div>
        <button
          type="button"
          onClick={() => navigate("/admin")}
          className="inline-flex items-center justify-center gap-2 rounded-full bg-white px-5 py-3 font-semibold text-cocoa shadow-sm transition hover:bg-oat"
        >
          <ChevronRight className="h-5 w-5 rotate-180" />
          返回后台
        </button>
      </div>

      <section className="mt-8 grid gap-8 lg:grid-cols-[1fr_380px]">
        <div className="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {quickProducts.map((product) => (
            <button
              key={product.id}
              type="button"
              onClick={() => updateCart(product.id, 1)}
              className="group rounded-lg border border-cocoa/10 bg-white text-left shadow-sm transition hover:-translate-y-1 hover:shadow-soft"
            >
              <ProductVisual product={product} />
              <div className="p-5">
                <div className="flex items-start justify-between gap-3">
                  <span>
                    <span className="block text-lg font-semibold">{product.name}</span>
                    <span className="mt-1 block text-sm text-cocoa/48">
                      {product.weight} · 本店剩余 {availableForStore(product.id)}
                    </span>
                  </span>
                  <span className="text-xl font-semibold text-crust">¥{product.price}</span>
                </div>
                <span className="mt-5 inline-flex items-center gap-2 rounded-full bg-cocoa px-4 py-2 text-sm font-semibold text-flour">
                  <Plus className="h-4 w-4" />
                  加到收银单
                </span>
              </div>
            </button>
          ))}
        </div>

        <aside className="rounded-lg border border-cocoa/10 bg-white p-5 shadow-soft lg:sticky lg:top-24 lg:self-start">
          <div className="flex items-center justify-between">
            <h2 className="text-2xl font-semibold">当前收银单</h2>
            <ReceiptText className="h-6 w-6 text-crust" />
          </div>
          <div className="mt-5 space-y-3">
            {cartItems.length === 0 ? (
              <p className="rounded-lg bg-oat p-4 text-sm text-cocoa/58">选择商品后生成收银单。</p>
            ) : (
              cartItems.map((item) => (
                <div key={item.productId} className="flex items-center justify-between border-b border-cocoa/8 pb-3">
                  <div>
                    <p className="font-semibold">{item.name}</p>
                    <p className="text-sm text-cocoa/48">¥{item.price} x {item.qty}</p>
                  </div>
                  <div className="flex items-center gap-2">
                    <button type="button" onClick={() => updateCart(item.productId, -1)} className="counter-button" aria-label="减少">
                      <Minus className="h-4 w-4" />
                    </button>
                    <button type="button" onClick={() => updateCart(item.productId, 1)} className="counter-button" aria-label="增加">
                      <Plus className="h-4 w-4" />
                    </button>
                  </div>
                </div>
              ))
            )}
          </div>

          <FormLabel label="现场收款" />
          <div className="grid grid-cols-2 gap-2">
            {paymentMethods.map((option) => {
              const Icon = option.icon;
              const active = paymentMethod === option.method;
              return (
                <button
                  key={option.method}
                  type="button"
                  onClick={() => setPaymentMethod(option.method)}
                  className={`flex items-center justify-center gap-2 rounded-lg px-3 py-3 text-sm font-semibold ${
                    active ? "bg-ember text-white" : "bg-oat text-cocoa/70"
                  }`}
                >
                  <Icon className="h-4 w-4" />
                  {option.method}
                </button>
              );
            })}
          </div>

          <div className="mt-6 flex items-center justify-between border-t border-cocoa/10 pt-5">
            <span className="text-sm text-cocoa/58">应收</span>
            <span className="text-4xl font-semibold">¥{subtotal}</span>
          </div>
          <button
            type="button"
            onClick={checkout}
            disabled={cartItems.length === 0}
            className="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-full bg-cocoa px-5 py-3 font-semibold text-flour transition hover:bg-crust disabled:cursor-not-allowed disabled:bg-cocoa/30"
          >
            <BadgeCheck className="h-5 w-5" />
            完成收银
          </button>
          {lastOrder && (
            <div className="mt-4 rounded-lg bg-green-50 p-4 text-sm text-green-900">
              {lastOrder.id} 已完成，归属 {store.name}
              {lastOrder.pickupCode ? `，取货码 ${lastOrder.pickupCode}` : ""}。
            </div>
          )}
        </aside>
      </section>
    </main>
  );
}

function getStoreName(stores: StoreLocation[], storeId: StoreId) {
  return stores.find((store) => store.id === storeId)?.name ?? storeId;
}

export default App;
