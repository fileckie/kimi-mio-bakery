          <input
            className="input-field bg-white"
            value={product.weight}
            onChange={(event) => setProduct((current) => ({ ...current, weight: event.target.value }))}
            placeholder="克重"
          />
          <input
            className="input-field bg-white"
            type="number"
            value={product.price}
            onChange={(event) => setProduct((current) => ({ ...current, price: Number(event.target.value) }))}
            placeholder="价格"
          />
