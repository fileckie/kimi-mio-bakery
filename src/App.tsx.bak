async function apiRequest<T>(path: string, options?: RequestInit): Promise<T> {
  const response = await fetch(path, {
    ...options,
    headers: {
      "content-type": "application/json",
      ...(options?.headers ?? {}),
    },
  });
  const data = await response.json();
  if (!response.ok) {
    throw new Error(data.error || "请求失败");
  }
  return data as T;
}

function readImageFile(file: File): Promise<string> {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(String(reader.result || ""));
    reader.onerror = () => reject(new Error("图片读取失败"));
    reader.readAsDataURL(file);
  });
}

function App() {
  const [route, setRoute] = useState<Route>(normalizeRoute(window.location.pathname));
  const [products, setProducts] = useState<Product[]>([]);
  const [stores, setStores] = useState<StoreLocation[]>([]);
  const [batchSale, setBatchSale] = useState<BatchSale>(emptyBatchSale);
  const [inventory, setInventory] = useState<InventoryAllocation>({});
  const [orders, setOrders] = useState<Order[]>([]);
  const [activeRole, setActiveRole] = useState<RoleId>("hq");
  const [apiError, setApiError] = useState<string | null>(null);

  useEffect(() => {
    const onPop = () => setRoute(normalizeRoute(window.location.pathname));
    window.addEventListener("popstate", onPop);
    return () => window.removeEventListener("popstate", onPop);
  }, []);

  useEffect(() => {
    void refreshData();
  }, []);

  const refreshData = async () => {
    try {
      const data = await apiRequest<BootstrapPayload>("/api/bootstrap");
      setProducts(data.products);
      setStores(data.stores);
      setBatchSale(data.batchSale);
      setInventory(data.inventory);
      setOrders(data.orders);
      setApiError(null);
    } catch (error) {
      setApiError(error instanceof Error ? error.message : "后端暂不可用，暂时无法读取门店数据");
    }
  };

  const navigate = (nextRoute: Route) => {
    window.history.pushState({}, "", nextRoute);
    setRoute(nextRoute);
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  const createOrder = async (order: Order) => {
    try {
      const endpoint = order.type === "pos" ? "/api/admin/pos-orders" : "/api/orders";
      const data = await apiRequest<{ order: Order; inventory: InventoryAllocation }>(endpoint, {
        method: "POST",
        body: JSON.stringify(order),
      });
      setOrders((current) => [data.order, ...current.filter((item) => item.id !== data.order.id)]);
      setInventory(data.inventory);
      setApiError(null);
      return data.order;
    } catch (error) {
      setApiError(error instanceof Error ? error.message : "订单保存失败");
      return null;
    }
  };

  return (
    <div className="min-h-screen bg-flour text-cocoa">
      {route === "/" ? (
        <CustomerHeader navigate={navigate} />
      ) : (
        <AdminHeader
          route={route}
          navigate={navigate}
          activeRole={activeRole}
          setActiveRole={setActiveRole}
          stores={stores}
        />
      )}
      {products.length === 0 || stores.length === 0 ? (
        <LoadingShell />
      ) : route === "/" ? (
        <CustomerPage
          products={products}
          stores={stores}
          batchSale={batchSale}
          inventory={inventory}
          createOrder={createOrder}
        />
      ) : null}
      {apiError && (
        <div className="fixed bottom-4 left-1/2 z-[80] max-w-[92vw] -translate-x-1/2 rounded-full bg-cocoa px-5 py-3 text-sm text-flour shadow-soft">
          {apiError}
        </div>
      )}
      {route === "/admin" && products.length > 0 && stores.length > 0 && (
        <AdminPage
          products={products}
          setProducts={setProducts}
          stores={stores}
          setStores={setStores}
          batchSale={batchSale}
          setBatchSale={setBatchSale}
          inventory={inventory}
          setInventory={setInventory}
          orders={orders}
          setOrders={setOrders}
          activeRole={activeRole}
          navigate={navigate}
          setApiError={setApiError}
        />
      )}
      {route === "/admin/pos" && products.length > 0 && stores.length > 0 && (
        <PosPage
          products={products}
          stores={stores}
          inventory={inventory}
          activeRole={activeRole}
          createOrder={createOrder}
          navigate={navigate}
        />
      )}
    </div>
  );
}

function normalizeRoute(pathname: string): Route {
  if (pathname === "/admin" || pathname === "/admin/pos") return pathname;
  return "/";
}

function LoadingShell() {
  return (
    <main className="flex min-h-[70svh] items-center justify-center px-4 py-24">
      <div className="rounded-lg border border-cocoa/10 bg-white p-6 text-center shadow-soft">
        <Flame className="mx-auto h-8 w-8 text-crust" />
        <p className="mt-4 font-semibold">正在读取 Mio Bakery 数据</p>
        <p className="mt-2 text-sm text-cocoa/52">商品、门店、库存和订单会从本地 SQLite 加载。</p>
      </div>
    </main>
  );
}

