  createProduct: () => void;
  uploadImage: (file?: File) => void;
}) {
  return (
    <div className="mt-5 rounded-lg border border-dashed border-cocoa/18 bg-flour p-4">
      <div className="flex items-center gap-2">
        <PackageOpen className="h-5 w-5 text-crust" />
